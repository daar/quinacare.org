# Mollie payment provider API key
# Get your key at https://my.mollie.com/dashboard/developers/api-keys
# Use test key (test_xxx) for development, live key (live_xxx) for production
MOLLIE_API_KEY=test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Turso database
# Get your credentials at https://turso.tech/app
TURSO_DATABASE_URL=libsql://your-database.turso.io
TURSO_AUTH_TOKEN=your-auth-token

# Mailtrap SMTP (contact form)
# Get your credentials at https://mailtrap.io/inboxes
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-pass
CONTACT_TO_EMAIL=care@quinacare.org
