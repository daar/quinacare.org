---
import "/src/styles/global.css";
import { Font } from "astro:assets";
import {
  getLangFromUrl,
  getAlternateUrls,
  defaultLang,
  type Lang,
} from "../i18n";

interface Props {
  title?: string;
  lang?: Lang;
  description?: string;
}

const currentLang = Astro.props.lang ?? getLangFromUrl(Astro.url);
const { title = "Quina Care - Zorg Zonder Grenzen", description } = Astro.props;
const alternateUrls = getAlternateUrls(Astro.url);

const metaDescription =
  description ||
  "Stichting Quina Care brengt medische expertise naar de meest afgelegen gebieden van de Amazone. Omdat elk leven telt.";
const canonicalURL = new URL(Astro.url.pathname, Astro.site).href;
const ogImage = new URL("/images/og-image.svg", Astro.site).href;
const ogLocale = { nl: "nl_NL", en: "en_US", es: "es_ES" }[currentLang];
// Cloudflare Web Analytics — only renders the beacon when the token
// is set, so local dev stays silent and production lights up.
const cfAnalyticsToken = import.meta.env.CF_ANALYTICS_TOKEN;
const structuredData = {
  "@context": "https://schema.org",
  "@type": "NGO",
  name: "Stichting Quina Care",
  alternateName: "Quina Care Foundation",
  url: "https://quinacare.org/",
  logo: "https://quinacare.org/logo-quina-care.svg",
  email: "care@quinacare.org",
  telephone: "+31630366030",
  description: metaDescription,
  address: {
    "@type": "PostalAddress",
    streetAddress: "IJsvogellaan 76",
    postalCode: "2261 DK",
    addressLocality: "Leidschendam",
    addressCountry: "NL",
  },
  sameAs: [
    "https://www.facebook.com/quinacare/",
    "https://www.instagram.com/quinacare/",
    "https://www.youtube.com/channel/UCyizISjNUBws4KdIIda9K7w",
    "https://www.linkedin.com/company/quina-care/",
  ],
};
---

<!doctype html>
<html lang={currentLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <script is:inline>
      // Language routing: on the site root, route the visitor to their
      // preferred locale. A remembered choice (localStorage "qc-lang") --
      // written here on first detection and by the language switcher --
      // always wins. Otherwise detect from the browser in preference
      // order; anything unsupported falls back to NL. Runs before paint
      // so there is no flash of the wrong locale.
      (function () {
        try {
          if (location.pathname !== "/") return;

          const supported = ["nl", "en", "es"];
          let lang = localStorage.getItem("qc-lang") || "";

          if (!supported.includes(lang)) {
            const prefs =
              navigator.languages && navigator.languages.length
                ? navigator.languages
                : [navigator.language || ""];
            lang =
              prefs
                .map((l) => l.toLowerCase().split("-")[0])
                .find((l) => supported.includes(l)) || "nl";
            localStorage.setItem("qc-lang", lang);
          }

          if (lang === "es") location.replace("/es/");
          else if (lang === "en") location.replace("/en/");
          // "nl" (and the unsupported -> nl fallback): stay on /
        } catch {
          /* storage/navigator unavailable - stay on / */
        }
      })();
    </script>
    <script is:inline>
      // Client-side error logger — persists errors to Turso so we can
      // analyse production issues iteratively. console.error is
      // invisible to end users; this beacon is our only after-the-
      // fact view. Capped at 5 reports per page load so a runaway
      // loop in third-party code can't flood the DB.
      (function () {
        let count = 0;
        const MAX = 5;
        function send(source, message, context) {
          if (count >= MAX) return;
          count++;
          try {
            navigator.sendBeacon(
              "/api/errors/log",
              new Blob(
                [
                  JSON.stringify({
                    source: source,
                    message: message,
                    context: context,
                  }),
                ],
                { type: "application/json" },
              ),
            );
          } catch {
            /* sendBeacon unavailable */
          }
        }
        window.addEventListener("error", function (e) {
          send("window.error", e.message || "unknown", {
            filename: e.filename,
            lineno: e.lineno,
            colno: e.colno,
            stack: e.error && e.error.stack,
            url: location.pathname,
          });
        });
        window.addEventListener("unhandledrejection", function (e) {
          const reason = e.reason;
          const message =
            typeof reason === "string"
              ? reason
              : (reason && reason.message) || "unhandled rejection";
          send("unhandledrejection", message, {
            stack: reason && reason.stack,
            url: location.pathname,
          });
        });
      })();
    </script>
    {
      cfAnalyticsToken && (
        <script
          is:inline
          defer
          crossorigin="anonymous"
          src="https://static.cloudflareinsights.com/beacon.min.js"
          data-cf-beacon={`{"token":"${cfAnalyticsToken}"}`}
        />
      )
    }
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <Font cssVariable="--astro-font-arimo" preload />
    <Font cssVariable="--astro-font-effra" preload />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={metaDescription} />
    <title>{title}</title>
    <link rel="canonical" href={canonicalURL} />
    <meta name="robots" content="index, follow" />
    <meta name="theme-color" content="#ee172c" />
    <link rel="apple-touch-icon" href="/favicon.svg" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Quina Care" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={metaDescription} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Quina Care" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={metaDescription} />
    <meta name="twitter:image" content={ogImage} />
    <script
      type="application/ld+json"
      is:inline
      set:html={JSON.stringify(structuredData)}
    />
    {
      alternateUrls.map(({ lang, url }) => (
        <link rel="alternate" hreflang={lang} href={url} />
      ))
    }
    <link
      rel="alternate"
      hreflang="x-default"
      href={alternateUrls.find((a) => a.lang === defaultLang)?.url}
    />
  </head>
  <body class="bg-white text-qcBlack">
    <slot />
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
    min-height: 100%;
  }
</style>
