---
import { getCollection, render } from "astro:content";
import { Image } from "astro:assets";
import Nav from "../../components/Nav.astro";
import Footer from "../../components/Footer.astro";
import "/src/styles/global.css";
import {
  useTranslations,
  getDateLocale,
  getLocalizedPath,
  type Lang,
} from "../../i18n";

const lang: Lang = "nl";
const t = useTranslations(lang);
const dateLocale = getDateLocale(lang);

export async function getStaticPaths() {
  const projects = await getCollection("projects-nl");
  return projects.map((entry) => ({
    params: { slug: entry.data.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

function formatDate(date: Date): string {
  return new Intl.DateTimeFormat(dateLocale, {
    day: "numeric",
    month: "long",
    year: "numeric",
  }).format(date);
}

function getStatusColor(status: string): string {
  switch (status) {
    case "active":
      return "bg-emerald-500";
    case "completed":
      return "bg-qcRed";
    case "upcoming":
      return "bg-amber-500";
    default:
      return "bg-gray-500";
  }
}

function getStatusLabel(status: string): string {
  switch (status) {
    case "active":
      return t("projects.active");
    case "completed":
      return t("projects.completed");
    case "upcoming":
      return t("projects.upcoming");
    default:
      return status;
  }
}

const shareUrl = `https://quinacare.org${getLocalizedPath(`/projects/${entry.data.slug}`, lang)}`;
const shareTitle = entry.data.title;
---

<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css"
      rel="stylesheet"
    />
    <meta name="generator" content={Astro.generator} />
    <meta
      name="description"
      content={entry.data.excerpt || `${entry.data.title} - Quina Care`}
    />
    <title>{entry.data.title} | Quina Care</title>
    <style>
      #progress-bar {
        height: 3px;
        background: var(--color-qcRed);
        width: 0%;
        position: fixed;
        top: 0;
        left: 0;
        z-index: 100;
        transition: width 0.1s ease;
      }
    </style>
  </head>
  <body class="text-qcBlack bg-white selection:bg-qcRed selection:text-white">
    <div id="progress-bar"></div>

    <Nav />

    <header class="pt-40 pb-16">
      <div class="max-w-3xl mx-auto px-6 text-center">
        <div class="flex items-center justify-center gap-3 mb-8">
          <span
            class={`${getStatusColor(entry.data.status)} text-white text-[9px] font-bold uppercase tracking-[0.3em] px-3 py-1 rounded-sm`}
          >
            {getStatusLabel(entry.data.status)}
          </span>
        </div>

        <h1
          class="text-4xl md:text-6xl font-bold tracking-tighter leading-[1.1] mb-8 uppercase"
        >
          {entry.data.title}
        </h1>

        <div
          class="flex items-center justify-center gap-4 text-[10px] font-bold uppercase tracking-widest text-gray-400 flex-wrap"
        >
          <span>{formatDate(entry.data.date)}</span>
        </div>
      </div>
    </header>

    {
      entry.data.featured_image && (
        <figure class="max-w-6xl mx-auto px-6 mb-24 group">
          <div class="relative">
            <div class="aspect-[21/9] overflow-hidden rounded-xl bg-gray-100 relative z-10">
              <Image
                src={entry.data.featured_image}
                class="w-full h-full object-cover transition-transform duration-[4s] ease-out group-hover:scale-105"
                alt={entry.data.featured_image_alt || entry.data.title}
                widths={[400, 800, 1200]}
                sizes="(max-width: 768px) 100vw, 1200px"
              />
            </div>
            <div class="absolute -top-4 -right-4 w-24 h-24 border-t-2 border-r-2 border-qcRed opacity-20 rounded-xl group-hover:translate-x-1 group-hover:-translate-y-1 transition-transform duration-700" />
            <div class="absolute -bottom-4 -left-4 w-24 h-24 border-b-2 border-l-2 border-gray-200 opacity-40 rounded-xl" />
          </div>
        </figure>
      )
    }

    <main
      class="max-w-7xl mx-auto px-6 flex flex-col md:flex-row gap-16 relative"
    >
      <aside class="hidden lg:block w-32 sticky top-32 h-fit">
        <div class="flex flex-col gap-6">
          <span
            class="text-[9px] font-bold uppercase tracking-widest text-gray-300 transform -rotate-90 origin-left translate-y-8"
          >
            {t("post.shareStory")}
          </span>
          <div class="h-12 w-px bg-gray-100 mx-auto mb-4"></div>
          <a
            href="https://www.instagram.com/quinacare/"
            target="_blank"
            rel="noopener noreferrer"
            class="w-10 h-10 flex items-center justify-center rounded-full border border-gray-100 hover:border-qcRed hover:text-qcRed transition"
          >
            <i class="fa-brands fa-instagram"></i>
          </a>
          <a
            href={`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(shareUrl)}`}
            target="_blank"
            rel="noopener noreferrer"
            class="w-10 h-10 flex items-center justify-center rounded-full border border-gray-100 hover:border-qcRed hover:text-qcRed transition"
          >
            <i class="fa-brands fa-facebook-f"></i>
          </a>
          <a
            href={`https://www.linkedin.com/shareArticle?mini=true&url=${encodeURIComponent(shareUrl)}&title=${encodeURIComponent(shareTitle)}`}
            target="_blank"
            rel="noopener noreferrer"
            class="w-10 h-10 flex items-center justify-center rounded-full border border-gray-100 hover:border-qcRed hover:text-qcRed transition"
          >
            <i class="fa-brands fa-linkedin-in"></i>
          </a>
          <a
            href={`mailto:?subject=${encodeURIComponent(shareTitle)}&body=${encodeURIComponent(shareTitle + "\n\n" + shareUrl + "\n\n— Quina Care")}`}
            class="w-10 h-10 flex items-center justify-center rounded-full border border-gray-100 hover:border-qcRed hover:text-qcRed transition"
          >
            <i class="fa-solid fa-envelope"></i>
          </a>
        </div>
      </aside>

      <div class="max-w-2xl mx-auto md:mx-0 flex-1">
        <article class="prose prose-article">
          <Content />
        </article>

        <div class="mt-20 pt-12 border-t border-gray-100">
          <a
            href={getLocalizedPath("/projects", lang)}
            class="inline-flex items-center gap-2 text-[10px] font-bold uppercase tracking-widest text-gray-400 hover:text-qcRed transition-colors group"
          >
            <svg
              class="w-4 h-4 group-hover:-translate-x-1 transition-transform"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path stroke-width="2" d="M15 19l-7-7 7-7"></path>
            </svg>
            {t("projects.backToList")}
          </a>
        </div>
      </div>
    </main>

    <Footer />

    <script>
      window.onscroll = function () {
        const winScroll =
          document.body.scrollTop || document.documentElement.scrollTop;
        const height =
          document.documentElement.scrollHeight -
          document.documentElement.clientHeight;
        const scrolled = (winScroll / height) * 100;
        const progressBar = document.getElementById("progress-bar");
        if (progressBar) {
          progressBar.style.width = scrolled + "%";
        }
      };
    </script>
  </body>
</html>
