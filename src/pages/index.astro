---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import Hero from "../components/Hero.astro";
import LiveMetrics from "../components/LiveMetrics.astro";
import News from "../components/News.astro";
import DonationCards from "../components/DonationCards.astro";
// TODO: re-enable FocusProject section
// import FocusProject from "../components/FocusProject.astro";
import Partners from "../components/Partners.astro";
// TODO: re-enable CallToAction banner
// import CallToAction from "../components/CallToAction.astro";
import Newsletter from "../components/Newsletter.astro";
import Footer from "../components/Footer.astro";
---

<Layout title="Quina Care - Zorg Zonder Grenzen">
  <Nav />
  <div data-pagefind-body>
    <Hero />
  </div>
  <LiveMetrics />
  <News />
  <DonationCards />
  {/* TODO: re-enable FocusProject section */}
  {/* <div data-pagefind-body><FocusProject /></div> */}
  <Partners />
  {/* TODO: re-enable CallToAction banner */}
  {/* <CallToAction /> */}
  <Newsletter />
  <Footer />
</Layout>

<script is:inline>
  // One-time browser-language redirect: on the first visit to the NL root,
  // route to the locale that matches the browser. NL browsers stay on /,
  // ES browsers go to /es/, and every other locale (EN as well as
  // unsupported languages) falls back to /en/. Runs once per session
  // so manual navigation back to / is respected.
  (function () {
    try {
      if (sessionStorage.getItem("qc-lang-auto") === "done") return;
      sessionStorage.setItem("qc-lang-auto", "done");

      const prefs = navigator.languages?.length
        ? navigator.languages
        : [navigator.language || "en"];
      const best = prefs
        .map((l) => l.toLowerCase().split("-")[0])
        .find((l) => ["nl", "en", "es"].includes(l));
      if (best === "nl") return;
      if (best === "es") location.replace("/es/");
      else location.replace("/en/");
    } catch {
      /* fall through and stay on / */
    }
  })();
</script>
