---
import { getCollection, render } from "astro:content";
import { Image } from "astro:assets";
import Layout from "../../layouts/Layout.astro";
import Nav from "../../components/Nav.astro";
import Footer from "../../components/Footer.astro";
import type { Lang } from "../../i18n";

const lang: Lang = "en";

export async function getStaticPaths() {
  const pages = await getCollection("pages-en");
  return pages.map((page) => ({
    params: { slug: page.data.slug },
    props: { page },
  }));
}

const { page } = Astro.props;
const { Content } = await render(page);
---

<Layout title={`${page.data.title} - Quina Care`} lang={lang}>
  <Nav />
  <div data-pagefind-body>
    <header class="pt-40 pb-16">
      <div class="max-w-3xl mx-auto px-6 text-center">
        {
          page.data.category_label && (
            <span class="text-qcRed text-[10px] font-bold uppercase tracking-[0.5em] mb-8 inline-block">
              {page.data.category_label}
            </span>
          )
        }
        <h1
          class="text-4xl md:text-6xl font-bold tracking-tighter leading-[1.1] mb-8 uppercase"
        >
          {page.data.title}
        </h1>
        {
          page.data.subtitle && (
            <p class="text-gray-400 text-lg md:text-xl max-w-2xl mx-auto leading-relaxed font-light">
              {page.data.subtitle}
            </p>
          )
        }
      </div>
    </header>

    {
      page.data.featured_image && (
        <figure class="max-w-5xl mx-auto px-6 mb-24 group">
          <div class="relative">
            <div class="overflow-hidden rounded-xl bg-gray-100 relative z-10">
              <Image
                src={page.data.featured_image}
                alt={page.data.featured_image_alt || page.data.title}
                class="w-full h-full object-cover transition-transform duration-[4s] ease-out group-hover:scale-105"
                widths={[400, 800, 1200]}
                sizes="(max-width: 768px) 100vw, 1024px"
              />
            </div>
            <div class="absolute -top-4 -right-4 w-24 h-24 border-t-2 border-r-2 border-qcRed opacity-20 rounded-xl group-hover:translate-x-1 group-hover:-translate-y-1 transition-transform duration-700" />
            <div class="absolute -bottom-4 -left-4 w-24 h-24 border-b-2 border-l-2 border-gray-200 opacity-40 rounded-xl" />
          </div>
        </figure>
      )
    }

    <article class="max-w-3xl mx-auto px-6 mb-16">
      <div class="prose-article max-w-none space-y-6">
        <Content />
      </div>
    </article>
  </div>
  <Footer lang={lang} />
</Layout>
