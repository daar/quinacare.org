---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import Nav from "../../components/Nav.astro";
import Footer from "../../components/Footer.astro";
import PageContent from "../../components/PageContent.astro";
import DonationModal from "../../components/DonationModal.astro";
import DonationFormCard from "../../components/DonationFormCard.astro";
import type { Lang } from "../../i18n";

const lang: Lang = "en";

export async function getStaticPaths() {
  // Draft pages are previewable in dev but excluded from production builds
  // (and therefore from the Pagefind search index).
  const pages = (await getCollection("pages-en")).filter(
    (page) => import.meta.env.DEV || !page.data.draft,
  );
  return pages.map((page) => ({
    params: { slug: page.data.slug },
    props: { page },
  }));
}

const { page } = Astro.props;
const isYuraBoom = page.data.slug === "yura-boom";
---

<Layout title={`${page.data.title} - Quina Care`} lang={lang}>
  <Nav />
  <div data-pagefind-body>
    <PageContent page={page} />
  </div>
  {
    isYuraBoom && (
      <DonationModal id="sponsor-modal">
        <DonationFormCard
          lang={lang}
          context="yura-boom"
          scopeId="yura-boom:sponsor"
          frequencies={["monthly", "quarterly", "yearly"]}
          defaultFrequency="monthly"
          allowCustom={false}
          impact={{ kind: "none" }}
          description="Quina Yura sponsor donation"
        />
      </DonationModal>
    )
  }
  <Footer lang={lang} />
</Layout>
