---
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import Layout from "../../layouts/Layout.astro";
import Nav from "../../components/Nav.astro";
import Footer from "../../components/Footer.astro";
import {
  useTranslations,
  getDateLocale,
  getLocalizedPath,
  type Lang,
} from "../../i18n";

const lang: Lang = "nl";
const t = useTranslations(lang);
const dateLocale = getDateLocale(lang);

const projects = await getCollection("projects-nl");
const sorted = projects.sort((a, b) => {
  const order = { active: 0, upcoming: 1, completed: 2 };
  return (
    (order[a.data.status] ?? 3) - (order[b.data.status] ?? 3) ||
    new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
  );
});

function formatDate(date: Date): string {
  return new Intl.DateTimeFormat(dateLocale, {
    day: "numeric",
    month: "long",
    year: "numeric",
  }).format(date);
}

function getStatusColor(status: string): string {
  switch (status) {
    case "active":
      return "bg-emerald-500";
    case "completed":
      return "bg-qcRed";
    case "upcoming":
      return "bg-amber-500";
    default:
      return "bg-gray-500";
  }
}

function getStatusLabel(status: string): string {
  switch (status) {
    case "active":
      return t("projects.active");
    case "completed":
      return t("projects.completed");
    case "upcoming":
      return t("projects.upcoming");
    default:
      return status;
  }
}
---

<Layout title={`${t("projects.title")} | Quina Care`} lang={lang}>
  <Nav />

  <header class="pt-40 pb-16 border-b border-gray-100">
    <div class="max-w-[1600px] mx-auto px-6">
      <span class="qc-label mb-4">
        {t("projects.subtitle")}
      </span>
      <h1 class="text-4xl md:text-6xl font-bold tracking-tighter leading-none">
        {t("projects.title")}<span class="italic font-light text-gray-300"
          >.</span
        >
      </h1>
    </div>
  </header>

  <main class="py-20 max-w-[1600px] mx-auto px-6">
    {
      sorted.length === 0 ? (
        <p class="text-gray-500 text-center text-lg">
          {t("projects.noProjects")}
        </p>
      ) : (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-x-8 gap-y-12">
          {sorted.map((project) => (
            <a
              href={getLocalizedPath(`/projects/${project.data.slug}`, lang)}
              class="group cursor-pointer block"
            >
              <article class="bg-white border border-gray-100 rounded-xl overflow-hidden hover:shadow-lg transition-shadow duration-300">
                <div class="aspect-[4/3] overflow-hidden bg-gray-100 relative">
                  {project.data.featured_image ? (
                    <Image
                      src={project.data.featured_image}
                      alt={
                        project.data.featured_image_alt || project.data.title
                      }
                      class="w-full h-full object-cover group-hover:scale-105 transition duration-700"
                      widths={[300, 600]}
                      sizes="(max-width: 768px) 100vw, (max-width: 1024px) 50vw, 33vw"
                    />
                  ) : (
                    <div class="w-full h-full bg-gradient-to-br from-gray-100 to-gray-200" />
                  )}
                  <div class="absolute top-4 left-4">
                    <span
                      class={`qc-meta ${getStatusColor(project.data.status)} !text-white px-3 py-1.5 rounded-sm`}
                    >
                      {getStatusLabel(project.data.status)}
                    </span>
                  </div>
                </div>

                <div class="p-5 md:p-6">
                  <div class="qc-meta mb-3">
                    {formatDate(project.data.date)}
                  </div>
                  <h3 class="text-base md:text-lg font-bold uppercase tracking-tight leading-tight group-hover:text-qcRed transition">
                    {project.data.title}
                  </h3>
                  {project.data.excerpt && (
                    <p class="qc-body mt-4 line-clamp-2">
                      {project.data.excerpt}
                    </p>
                  )}
                  <div class="qc-meta mt-6 flex items-center gap-2 !text-qcRed">
                    {t("projects.readMore")}
                    <svg
                      class="w-4 h-4 group-hover:translate-x-1 transition-transform"
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                    >
                      <path stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                    </svg>
                  </div>
                </div>
              </article>
            </a>
          ))}
        </div>
      )
    }
  </main>

  <Footer />
</Layout>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
