---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import { getLangFromUrl, useTranslations, getLocalizedPath } from "../i18n";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<Layout title={`${t("404.title")} | Quina Care`} lang={lang}>
  <Nav />

  <main
    class="relative min-h-[calc(100dvh-5rem)] flex items-center justify-center overflow-hidden"
  >
    <div
      class="absolute inset-0 bg-gradient-to-br from-white via-rose-50/40 to-white"
    >
    </div>

    <div
      class="absolute inset-0 overflow-hidden pointer-events-none"
      aria-hidden="true"
    >
      <div
        class="absolute -top-24 -right-24 w-96 h-96 rounded-full bg-qcRed/5 blur-3xl animate-float-slow"
      >
      </div>
      <div
        class="absolute -bottom-32 -left-32 w-[500px] h-[500px] rounded-full bg-rose-100/50 blur-3xl animate-float-slower"
      >
      </div>
      <div
        class="absolute top-1/3 left-1/4 w-64 h-64 rounded-full bg-qcRed/3 blur-2xl animate-float-reverse"
      >
      </div>
    </div>

    <div class="relative z-10 text-center px-6 max-w-2xl mx-auto">
      <div class="mb-8 inline-flex items-center justify-center">
        <span
          class="error-code text-[12rem] md:text-[16rem] font-bold tracking-tighter leading-none text-transparent bg-clip-text bg-gradient-to-b from-qcRed via-rose-400 to-rose-200 select-none"
        >
          {t("404.subtitle")}
        </span>
      </div>

      <div class="space-y-4 mb-10">
        <h1 class="text-3xl md:text-4xl font-bold tracking-tighter uppercase">
          {t("404.title")}
        </h1>
        <p
          class="text-gray-400 text-sm md:text-base max-w-md mx-auto leading-relaxed"
        >
          {t("404.description")}
        </p>
      </div>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href={getLocalizedPath("/", lang)}
          class="group relative inline-flex items-center gap-3 font-bold text-sm uppercase tracking-widest px-8 py-4 rounded-lg overflow-hidden transition-all duration-300 hover:-translate-y-0.5 hover:shadow-xl"
        >
          <div
            class="absolute inset-0 bg-qcRed group-hover:bg-red-700 transition-colors duration-300"
          >
          </div>
          <svg
            class="relative w-4 h-4 text-white group-hover:-translate-x-1 transition-transform duration-300"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path stroke-width="2" d="M15 19l-7-7 7-7"></path>
          </svg>
          <span class="relative text-white">{t("404.backHome")}</span>
        </a>
      </div>

      <div class="mt-16 flex items-center justify-center gap-8 text-gray-300">
        <a
          href={getLocalizedPath("/news", lang)}
          class="text-[10px] font-bold uppercase tracking-widest hover:text-qcRed transition-colors duration-300"
        >
          News
        </a>
        <span class="w-1 h-1 rounded-full bg-gray-200"></span>
        <a
          href={getLocalizedPath("/fundraise", lang)}
          class="text-[10px] font-bold uppercase tracking-widest hover:text-qcRed transition-colors duration-300"
        >
          {t("fundraise.title")}
        </a>
        <span class="w-1 h-1 rounded-full bg-gray-200"></span>
        <a
          href={getLocalizedPath("/donate", lang)}
          class="text-[10px] font-bold uppercase tracking-widest hover:text-qcRed transition-colors duration-300"
        >
          {t("nav.donate")}
        </a>
      </div>
    </div>
  </main>

  <Footer />
</Layout>

<style>
  .error-code {
    animation: fadeInUp 0.8s cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes floatSlow {
    0%,
    100% {
      transform: translate(0, 0);
    }
    50% {
      transform: translate(20px, -30px);
    }
  }

  @keyframes floatSlower {
    0%,
    100% {
      transform: translate(0, 0);
    }
    50% {
      transform: translate(-25px, 20px);
    }
  }

  @keyframes floatReverse {
    0%,
    100% {
      transform: translate(0, 0);
    }
    50% {
      transform: translate(15px, 25px);
    }
  }

  :global(.animate-float-slow) {
    animation: floatSlow 8s ease-in-out infinite;
  }

  :global(.animate-float-slower) {
    animation: floatSlower 12s ease-in-out infinite;
  }

  :global(.animate-float-reverse) {
    animation: floatReverse 10s ease-in-out infinite;
  }
</style>
