---
import Icon from "../../../components/Icon.astro";
import { getCollection, render } from "astro:content";
import { Image } from "astro:assets";
import Layout from "../../../layouts/Layout.astro";
import Nav from "../../../components/Nav.astro";
import Footer from "../../../components/Footer.astro";
import {
  useTranslations,
  getDateLocale,
  getLocalizedPath,
  type Lang,
} from "../../../i18n";
import DonationModal from "../../../components/DonationModal.astro";
import DonationFormCard from "../../../components/DonationFormCard.astro";
import SocialShare from "../../../components/SocialShare.astro";
import { generateQrDataUri } from "../../../lib/qr";

const lang: Lang = "es";
const t = useTranslations(lang);
const dateLocale = getDateLocale(lang);

export async function getStaticPaths() {
  // Draft fundraisers are previewable in dev but excluded from production.
  const fundraisers = (await getCollection("fundraisers-es")).filter(
    (entry) => import.meta.env.DEV || !entry.data.draft,
  );
  return fundraisers.map((entry) => ({
    params: { slug: entry.data.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const pct = Math.min(
  100,
  Math.round((entry.data.raised_offset / entry.data.goal_amount) * 100),
);
const daysToGo = Math.max(
  0,
  Math.ceil(
    (entry.data.end_date.getTime() - Date.now()) / (1000 * 60 * 60 * 24),
  ),
);

function formatCurrency(amount: number): string {
  return new Intl.NumberFormat("es-ES", {
    style: "currency",
    currency: "EUR",
    minimumFractionDigits: 0,
    maximumFractionDigits: 0,
  }).format(amount);
}

function formatDate(date: Date): string {
  return new Intl.DateTimeFormat(dateLocale, {
    day: "numeric",
    month: "long",
    year: "numeric",
  }).format(date);
}

// A fundraiser counts as active until its end date passes.
const isActive = entry.data.end_date.getTime() > Date.now();

const shareUrl = `https://quinacare.org${getLocalizedPath(`/fundraisers/${entry.data.slug}`, lang)}`;
const shareTitle = entry.data.title;
const qrDataUri = await generateQrDataUri(shareUrl);
---

<Layout title={`${entry.data.title} | Quina Care`} lang={lang}>
  <Nav />

  <div class="max-w-[1600px] mx-auto px-6 pt-32 pb-6">
    <a
      href={getLocalizedPath("/fundraisers", lang)}
      class="qc-meta inline-flex items-center gap-2 hover:text-qcRed transition-colors group"
    >
      <svg
        class="w-4 h-4 group-hover:-translate-x-1 transition-transform"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
      >
        <path stroke-width="2" d="M15 19l-7-7 7-7"></path>
      </svg>
      {t("fundraise.backToList")}
    </a>

    <div class="mt-6 mb-8">
      {
        isActive && (
          <div class="flex items-center gap-3 mb-4">
            <span class="qc-meta bg-emerald-500 !text-white px-3 py-1.5 rounded-full">
              {t("fundraise.active")}
            </span>
          </div>
        )
      }
      <h1
        class="text-3xl md:text-4xl lg:text-5xl font-bold tracking-tighter leading-[1.1] uppercase"
      >
        {entry.data.title}
      </h1>
      <p class="text-sm text-gray-400 mt-3">
        {t("fundraise.campaignBy")}
        <span class="text-qcBlack font-bold">{entry.data.organizer}</span>
      </p>
    </div>
  </div>

  <div class="max-w-[1600px] mx-auto px-6 pb-12">
    <div class="grid grid-cols-1 lg:grid-cols-5 gap-8 lg:gap-10">
      <div class="lg:col-span-3 lg:flex lg:items-center">
        <div
          class="w-full aspect-video rounded-xl overflow-hidden bg-gray-100 relative"
        >
          {
            entry.data.featured_image ? (
              <Image
                src={entry.data.featured_image}
                alt={entry.data.featured_image_alt || entry.data.title}
                class="w-full h-full object-cover"
                widths={[400, 800, 1200]}
                sizes="(max-width: 1024px) 100vw, 60vw"
              />
            ) : (
              <div class="w-full h-full bg-gradient-to-br from-gray-100 to-gray-200 flex items-center justify-center">
                <Icon name="heart" class="text-gray-300 text-5xl" />
              </div>
            )
          }
        </div>
      </div>

      <div class="lg:col-span-2">
        <div
          class="relative rounded-xl border border-gray-200 bg-white shadow-sm overflow-hidden hover:shadow-lg transition-shadow duration-300 h-full flex flex-col"
        >
          <div
            class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-qcRed via-rose-400 to-qcRed"
          >
          </div>

          <div class="p-6 md:p-8 flex flex-col flex-1">
            <div class="mb-6">
              <div
                class="w-full bg-gray-100 rounded-full h-3 overflow-hidden mb-4"
              >
                <div
                  class="progress-fill bg-gradient-to-r from-qcRed to-rose-400 h-3 rounded-full relative"
                  style={`width: ${pct}%`}
                >
                  <div
                    class="absolute inset-0 rounded-full bg-white/20 animate-pulse-subtle"
                  >
                  </div>
                </div>
              </div>

              <div
                class="fundraiser-raised text-3xl md:text-4xl font-bold tracking-tight mb-1"
                data-slug={entry.data.slug}
                data-goal={entry.data.goal_amount}
                data-locale="es-ES"
                data-currency="EUR"
                data-initial-raised={entry.data.raised_offset}
                data-initial-backers={entry.data.backers_offset}
              >
                {formatCurrency(entry.data.raised_offset)}
              </div>
              <p class="text-sm text-gray-400">
                {t("fundraise.raised")}
                {t("fundraise.of")}
                {formatCurrency(entry.data.goal_amount)}
                {t("fundraise.goal")}
              </p>
            </div>

            <div
              class="grid grid-cols-2 gap-4 py-5 border-t border-gray-100 mb-6"
            >
              <div>
                <div class="fundraiser-pct text-2xl font-bold tracking-tight">
                  {pct}%
                </div>
                <div class="qc-meta">
                  {t("fundraise.funded")}
                </div>
              </div>
              <div>
                <div
                  class="fundraiser-backers text-2xl font-bold tracking-tight"
                >
                  {entry.data.backers_offset}
                </div>
                <div class="qc-meta">
                  {t("fundraise.backers")}
                </div>
              </div>
            </div>

            <div
              class="flex items-center gap-3 pb-6 border-b border-gray-100 mb-6"
            >
              <div
                class="w-10 h-10 rounded-lg bg-gray-50 flex items-center justify-center flex-shrink-0"
              >
                <Icon name="clock" class="text-gray-400" />
              </div>
              <div>
                <div class="text-xl font-bold tracking-tight">{daysToGo}</div>
                <div class="qc-meta">
                  {t("fundraise.daysToGo")}
                </div>
              </div>
            </div>

            <button
              type="button"
              data-open-modal="fundraiser-donate-modal"
              class="group relative block w-full text-center font-bold text-sm uppercase tracking-widest py-4 rounded-lg overflow-hidden transition-all duration-300 hover:-translate-y-0.5 hover:shadow-lg mb-4"
            >
              <div
                class="absolute inset-0 bg-qcRed group-hover:bg-red-700 transition-colors duration-300"
              >
              </div>
              <span class="relative text-white">{t("fundraise.donateNow")}</span
              >
            </button>

            <div class="flex items-center justify-center gap-3 mt-auto pt-4">
              <span class="qc-meta !text-gray-300 mr-1"
                >{t("post.shareStory")}</span
              >
              <SocialShare
                url={shareUrl}
                title={shareTitle}
                orientation="horizontal"
                lang={lang}
              />
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="border-t border-gray-100"></div>
  <main class="max-w-[1600px] mx-auto px-6 py-12">
    <div class="grid grid-cols-1 lg:grid-cols-5 gap-10">
      <div class="lg:col-span-3">
        <article class="prose prose-article max-w-none">
          <Content />
        </article>
      </div>
      <div class="lg:col-span-2">
        <div class="sticky top-28 space-y-6">
          <div
            class="rounded-xl border border-gray-200 bg-white p-6 shadow-sm hover:shadow-lg transition-shadow duration-300"
          >
            <div class="flex items-center gap-4 mb-4">
              <div
                class="w-12 h-12 rounded-full bg-gradient-to-br from-qcRed/20 to-rose-100 flex items-center justify-center flex-shrink-0"
              >
                <Icon name="user" class="text-lg text-qcRed" />
              </div>
              <div>
                <div class="qc-meta mb-0.5">
                  {t("fundraise.campaignBy")}
                </div>
                <div class="font-bold tracking-tight">
                  {entry.data.organizer}
                </div>
              </div>
            </div>
            <p class="text-sm text-gray-500 leading-relaxed">
              {entry.data.excerpt}
            </p>
          </div>

          <div class="rounded-xl border border-gray-200 bg-white p-6 shadow-sm">
            <div class="flex items-center gap-3">
              <div
                class="w-10 h-10 rounded-lg bg-gray-50 flex items-center justify-center flex-shrink-0"
              >
                <Icon name="calendar" class="text-gray-400" />
              </div>
              <div>
                <div class="qc-meta">
                  {t("fundraise.endDate")}
                </div>
                <div class="font-bold tracking-tight">
                  {formatDate(entry.data.end_date)}
                </div>
              </div>
            </div>
          </div>

          <!-- QR code card -->
          <div
            class="rounded-xl border border-gray-200 bg-white p-6 shadow-sm text-center"
          >
            <div class="qc-meta mb-4">{t("fundraise.qrTitle")}</div>
            <img
              src={qrDataUri}
              alt={`${t("fundraise.qrTitle")} – ${entry.data.title}`}
              width="200"
              height="200"
              class="mx-auto rounded-lg"
            />
            <a
              href={qrDataUri}
              download={`quinacare-${entry.data.slug}-qr.png`}
              class="mt-5 flex items-center justify-center gap-2 w-full font-bold text-xs uppercase tracking-widest py-3 rounded-lg border border-gray-200 text-gray-500 hover:border-qcRed hover:text-qcRed transition-colors"
            >
              <Icon name="download" />
              {t("fundraise.qrDownload")}
            </a>
          </div>
        </div>
      </div>
    </div>
  </main>

  <DonationModal id="fundraiser-donate-modal">
    <DonationFormCard
      lang={lang}
      context="fundraiser"
      scopeId={`fundraiser:${entry.data.slug}`}
      frequencies={["one-time"]}
      impact={{
        kind: "fundraiser",
        organizer: entry.data.organizer,
        fallback: entry.data.title,
        excerpt: entry.data.excerpt,
      }}
      metadata={{
        fundraiser_slug: entry.data.slug,
        fundraiser_title: entry.data.title,
      }}
    />
  </DonationModal>

  <Footer />
</Layout>

<style>
  .progress-fill {
    width: 0% !important;
    transition: width 1.4s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .progress-fill.animate {
    width: var(--target-width) !important;
  }

  @keyframes pulse-subtle {
    0%,
    100% {
      opacity: 0;
    }
    50% {
      opacity: 0.3;
    }
  }
  .animate-pulse-subtle {
    animation: pulse-subtle 2.5s ease-in-out infinite;
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    document.querySelectorAll(".progress-fill").forEach((bar) => {
      const el = bar as HTMLElement;
      el.style.setProperty("--target-width", el.style.width);
      el.style.width = "0%";
      requestAnimationFrame(() => {
        requestAnimationFrame(() => {
          el.classList.add("animate");
        });
      });
    });

    const raisedEl = document.querySelector<HTMLElement>(".fundraiser-raised");
    if (!raisedEl) return;

    const slug = raisedEl.dataset.slug!;
    const goal = Number(raisedEl.dataset.goal);
    const locale = raisedEl.dataset.locale!;
    const currency = raisedEl.dataset.currency!;
    const raisedOffset = Number(raisedEl.dataset.initialRaised);
    const backersOffset = Number(raisedEl.dataset.initialBackers);

    fetch(`/api/fundraisers/stats?slug=${encodeURIComponent(slug)}`)
      .then((r) => r.json())
      .then((data: { raised_cents: number; donor_count: number }) => {
        // Live Turso totals plus the frontmatter offset, which covers
        // off-site donations or any missing from the database.
        const totalRaised = raisedOffset + data.raised_cents / 100;
        const totalBackers = backersOffset + data.donor_count;
        const pct = Math.min(100, Math.round((totalRaised / goal) * 100));

        const fmt = new Intl.NumberFormat(locale, {
          style: "currency",
          currency,
          minimumFractionDigits: 0,
          maximumFractionDigits: 0,
        });

        raisedEl.textContent = fmt.format(totalRaised);

        const pctEl = document.querySelector<HTMLElement>(".fundraiser-pct");
        if (pctEl) pctEl.textContent = `${pct}%`;

        const backersEl = document.querySelector<HTMLElement>(
          ".fundraiser-backers",
        );
        if (backersEl) backersEl.textContent = String(totalBackers);

        const bar = document.querySelector<HTMLElement>(".progress-fill");
        if (bar) {
          bar.style.setProperty("--target-width", `${pct}%`);
        }
      })
      .catch(() => {});
  });
</script>
