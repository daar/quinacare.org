---
import type { GetStaticPaths } from "astro";
import { getCollection } from "astro:content";
import Layout from "../../../layouts/Layout.astro";
import Nav from "../../../components/Nav.astro";
import Footer from "../../../components/Footer.astro";
import BlogRoll from "../../../components/BlogRoll.astro";
import { useTranslations, type Lang } from "../../../i18n";
import { orderNews } from "../../../lib/news";

const lang: Lang = "es";
const t = useTranslations(lang);

export const getStaticPaths = (() => [
  { params: { page: undefined } },
]) satisfies GetStaticPaths;

const all = await getCollection("news-es");
const posts = orderNews(
  all.filter((post) => post.data.status === "publish"),
  all.length,
);
---

<Layout title={`${t("nav.news")} | Quina Care`} lang={lang}>
  <Nav />
  <BlogRoll posts={posts} lang={lang} />
  <Footer />
</Layout>
