---
import { getCollection, render } from "astro:content";
import { Image } from "astro:assets";
import Layout from "../../../layouts/Layout.astro";
import Nav from "../../../components/Nav.astro";
import Footer from "../../../components/Footer.astro";
import {
  useTranslations,
  getDateLocale,
  getLocalizedPath,
  type Lang,
} from "../../../i18n";

const lang: Lang = "es";
const t = useTranslations(lang);
const dateLocale = getDateLocale(lang);

export async function getStaticPaths() {
  const fundraisers = await getCollection("fundraisers-es");
  return fundraisers.map((entry) => ({
    params: { slug: entry.data.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const pct = Math.min(
  100,
  Math.round((entry.data.raised_amount / entry.data.goal_amount) * 100),
);
const daysToGo = Math.max(
  0,
  Math.ceil(
    (entry.data.end_date.getTime() - Date.now()) / (1000 * 60 * 60 * 24),
  ),
);

function formatCurrency(amount: number): string {
  return new Intl.NumberFormat("es-ES", {
    style: "currency",
    currency: "EUR",
    minimumFractionDigits: 0,
    maximumFractionDigits: 0,
  }).format(amount);
}

function formatDate(date: Date): string {
  return new Intl.DateTimeFormat(dateLocale, {
    day: "numeric",
    month: "long",
    year: "numeric",
  }).format(date);
}

function getStatusColor(status: string): string {
  switch (status) {
    case "active":
      return "bg-emerald-500";
    case "completed":
      return "bg-qcRed";
    case "upcoming":
      return "bg-amber-500";
    default:
      return "bg-gray-500";
  }
}

function getStatusLabel(status: string): string {
  switch (status) {
    case "active":
      return t("fundraise.active");
    case "completed":
      return t("fundraise.completed");
    case "upcoming":
      return t("fundraise.upcoming");
    default:
      return status;
  }
}

const shareUrl = `https://quinacare.org${getLocalizedPath(`/fundraise/${entry.data.slug}`, lang)}`;
const shareTitle = entry.data.title;
---

<Layout title={`${entry.data.title} | Quina Care`} lang={lang}>
  <Nav />

  <div class="max-w-[1600px] mx-auto px-6 pt-32 pb-6">
    <a
      href={getLocalizedPath("/fundraise", lang)}
      class="inline-flex items-center gap-2 text-[10px] font-bold uppercase tracking-widest text-gray-400 hover:text-qcRed transition-colors group"
    >
      <svg
        class="w-4 h-4 group-hover:-translate-x-1 transition-transform"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
      >
        <path stroke-width="2" d="M15 19l-7-7 7-7"></path>
      </svg>
      {t("fundraise.backToList")}
    </a>

    <div class="mt-6 mb-8">
      <div class="flex items-center gap-3 mb-4">
        <span
          class={`${getStatusColor(entry.data.status)} text-white text-[9px] font-bold uppercase tracking-widest px-3 py-1.5 rounded-full`}
        >
          {getStatusLabel(entry.data.status)}
        </span>
      </div>
      <h1
        class="text-3xl md:text-4xl lg:text-5xl font-bold tracking-tighter leading-[1.1] uppercase"
      >
        {entry.data.title}
      </h1>
      <p class="text-sm text-gray-400 mt-3">
        {t("fundraise.campaignBy")}
        <span class="text-qcBlack font-bold">{entry.data.organizer}</span>
      </p>
    </div>
  </div>

  <div class="max-w-[1600px] mx-auto px-6 pb-12">
    <div class="grid grid-cols-1 lg:grid-cols-5 gap-8 lg:gap-10">
      <div class="lg:col-span-3">
        <div
          class="aspect-video rounded-xl overflow-hidden bg-gray-100 relative"
        >
          {
            entry.data.featured_image ? (
              <Image
                src={entry.data.featured_image}
                alt={entry.data.featured_image_alt || entry.data.title}
                class="w-full h-full object-cover"
                widths={[400, 800, 1200]}
                sizes="(max-width: 1024px) 100vw, 60vw"
              />
            ) : (
              <div class="w-full h-full bg-gradient-to-br from-gray-100 to-gray-200 flex items-center justify-center">
                <i class="fa-solid fa-heart text-gray-300 text-5xl" />
              </div>
            )
          }
        </div>
      </div>

      <div class="lg:col-span-2">
        <div
          class="relative rounded-xl border border-gray-200 bg-white shadow-sm overflow-hidden hover:shadow-lg transition-shadow duration-300 h-full flex flex-col"
        >
          <div
            class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-qcRed via-rose-400 to-qcRed"
          >
          </div>

          <div class="p-6 md:p-8 flex flex-col flex-1">
            <div class="mb-6">
              <div
                class="w-full bg-gray-100 rounded-full h-3 overflow-hidden mb-4"
              >
                <div
                  class="progress-fill bg-gradient-to-r from-qcRed to-rose-400 h-3 rounded-full relative"
                  style={`width: ${pct}%`}
                >
                  <div
                    class="absolute inset-0 rounded-full bg-white/20 animate-pulse-subtle"
                  >
                  </div>
                </div>
              </div>

              <div class="text-3xl md:text-4xl font-bold tracking-tight mb-1">
                {formatCurrency(entry.data.raised_amount)}
              </div>
              <p class="text-sm text-gray-400">
                {t("fundraise.raised")}
                {t("fundraise.of")}
                {formatCurrency(entry.data.goal_amount)}
                {t("fundraise.goal")}
              </p>
            </div>

            <div
              class="grid grid-cols-2 gap-4 py-5 border-t border-gray-100 mb-6"
            >
              <div>
                <div class="text-2xl font-bold tracking-tight">{pct}%</div>
                <div
                  class="text-[10px] text-gray-400 font-bold uppercase tracking-wide"
                >
                  {t("fundraise.funded")}
                </div>
              </div>
              <div>
                <div class="text-2xl font-bold tracking-tight">
                  {entry.data.backers}
                </div>
                <div
                  class="text-[10px] text-gray-400 font-bold uppercase tracking-wide"
                >
                  {t("fundraise.backers")}
                </div>
              </div>
            </div>

            <div
              class="flex items-center gap-3 pb-6 border-b border-gray-100 mb-6"
            >
              <div
                class="w-10 h-10 rounded-lg bg-gray-50 flex items-center justify-center flex-shrink-0"
              >
                <i class="fa-regular fa-clock text-gray-400"></i>
              </div>
              <div>
                <div class="text-xl font-bold tracking-tight">{daysToGo}</div>
                <div
                  class="text-[10px] text-gray-400 font-bold uppercase tracking-wide"
                >
                  {t("fundraise.daysToGo")}
                </div>
              </div>
            </div>

            <a
              href={getLocalizedPath("/donate", lang)}
              class="group relative block w-full text-center font-bold text-sm uppercase tracking-widest py-4 rounded-lg overflow-hidden transition-all duration-300 hover:-translate-y-0.5 hover:shadow-lg mb-4"
            >
              <div
                class="absolute inset-0 bg-qcRed group-hover:bg-red-700 transition-colors duration-300"
              >
              </div>
              <span class="relative text-white">{t("fundraise.donateNow")}</span
              >
            </a>

            <div class="flex items-center justify-center gap-3 mt-auto pt-4">
              <span
                class="text-[9px] font-bold uppercase tracking-widest text-gray-300 mr-1"
                >{t("post.shareStory")}</span
              >
              <a
                href={`https://twitter.com/intent/tweet?url=${encodeURIComponent(shareUrl)}&text=${encodeURIComponent(shareTitle)}`}
                target="_blank"
                rel="noopener noreferrer"
                class="w-8 h-8 flex items-center justify-center rounded-full border border-gray-200 text-gray-400 hover:border-qcRed hover:text-qcRed transition-colors"
                ><i class="fa-brands fa-x-twitter text-xs"></i></a
              >
              <a
                href={`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(shareUrl)}`}
                target="_blank"
                rel="noopener noreferrer"
                class="w-8 h-8 flex items-center justify-center rounded-full border border-gray-200 text-gray-400 hover:border-qcRed hover:text-qcRed transition-colors"
                ><i class="fa-brands fa-facebook-f text-xs"></i></a
              >
              <a
                href={`https://www.linkedin.com/shareArticle?mini=true&url=${encodeURIComponent(shareUrl)}&title=${encodeURIComponent(shareTitle)}`}
                target="_blank"
                rel="noopener noreferrer"
                class="w-8 h-8 flex items-center justify-center rounded-full border border-gray-200 text-gray-400 hover:border-qcRed hover:text-qcRed transition-colors"
                ><i class="fa-brands fa-linkedin-in text-xs"></i></a
              >
              <a
                href={`mailto:?subject=${encodeURIComponent(shareTitle)}&body=${encodeURIComponent(shareUrl)}`}
                class="w-8 h-8 flex items-center justify-center rounded-full border border-gray-200 text-gray-400 hover:border-qcRed hover:text-qcRed transition-colors"
                ><i class="fa-solid fa-envelope text-xs"></i></a
              >
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="border-t border-gray-100"></div>
  <main class="max-w-[1600px] mx-auto px-6 py-12">
    <div class="grid grid-cols-1 lg:grid-cols-5 gap-10">
      <div class="lg:col-span-3">
        <article class="prose prose-article max-w-none">
          <Content />
        </article>
      </div>
      <div class="lg:col-span-2">
        <div class="sticky top-28 space-y-6">
          <div
            class="rounded-xl border border-gray-200 bg-white p-6 shadow-sm hover:shadow-lg transition-shadow duration-300"
          >
            <div class="flex items-center gap-4 mb-4">
              <div
                class="w-12 h-12 rounded-full bg-gradient-to-br from-qcRed/20 to-rose-100 flex items-center justify-center flex-shrink-0"
              >
                <i class="fa-solid fa-user text-lg text-qcRed"></i>
              </div>
              <div>
                <div
                  class="text-[9px] font-bold uppercase tracking-widest text-gray-400 mb-0.5"
                >
                  {t("fundraise.campaignBy")}
                </div>
                <div class="font-bold tracking-tight">
                  {entry.data.organizer}
                </div>
              </div>
            </div>
            <p class="text-sm text-gray-500 leading-relaxed">
              {entry.data.excerpt}
            </p>
          </div>

          <div class="rounded-xl border border-gray-200 bg-white p-6 shadow-sm">
            <div class="flex items-center gap-3">
              <div
                class="w-10 h-10 rounded-lg bg-gray-50 flex items-center justify-center flex-shrink-0"
              >
                <i class="fa-regular fa-calendar text-gray-400"></i>
              </div>
              <div>
                <div
                  class="text-[9px] font-bold uppercase tracking-widest text-gray-400"
                >
                  {t("fundraise.endDate")}
                </div>
                <div class="font-bold tracking-tight">
                  {formatDate(entry.data.end_date)}
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>

  <Footer />
</Layout>

<style>
  .progress-fill {
    width: 0% !important;
    transition: width 1.4s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .progress-fill.animate {
    width: var(--target-width) !important;
  }

  @keyframes pulse-subtle {
    0%,
    100% {
      opacity: 0;
    }
    50% {
      opacity: 0.3;
    }
  }
  .animate-pulse-subtle {
    animation: pulse-subtle 2.5s ease-in-out infinite;
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    document.querySelectorAll(".progress-fill").forEach((bar) => {
      const el = bar as HTMLElement;
      el.style.setProperty("--target-width", el.style.width);
      el.style.width = "0%";
      requestAnimationFrame(() => {
        requestAnimationFrame(() => {
          el.classList.add("animate");
        });
      });
    });
  });
</script>
