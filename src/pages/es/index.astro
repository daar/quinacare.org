  <LiveMetrics lang={lang} />
  <News lang={lang} />
  <DonationCards lang={lang} />
  {/* TODO: re-enable FocusProject section */}
  {/* <div data-pagefind-body><FocusProject lang={lang} /></div> */}
  <Partners lang={lang} />
  {/* TODO: re-enable CallToAction banner */}
  {/* <CallToAction lang={lang} /> */}
  <Newsletter lang={lang} />
  <Footer lang={lang} />
</Layout>
