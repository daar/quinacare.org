---
import Layout from "../../layouts/Layout.astro";
import Nav from "../../components/Nav.astro";
import Hero from "../../components/Hero.astro";
import LiveMetrics from "../../components/LiveMetrics.astro";
import News from "../../components/News.astro";
import DonationCards from "../../components/DonationCards.astro";
// TODO: re-enable FocusProject section
// import FocusProject from "../../components/FocusProject.astro";
import Partners from "../../components/Partners.astro";
// TODO: re-enable CallToAction banner
// import CallToAction from "../../components/CallToAction.astro";
import Newsletter from "../../components/Newsletter.astro";
import Footer from "../../components/Footer.astro";
import type { Lang } from "../../i18n";

const lang: Lang = "es";
---

<Layout title="Stichting Quina Care / Hospital San Miguel" lang={lang}>
