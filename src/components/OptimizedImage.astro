---
import { Image } from "astro:assets";
import { resolveImage } from "../lib/images";

interface Props {
  src: string;
  alt: string;
  class?: string;
  width?: number;
  height?: number;
  widths?: number[];
  sizes?: string;
  loading?: "eager" | "lazy";
  /** Astro image layout. Pass "none" to opt out of the global
   * "constrained" layout (which forces height:auto) when the image
   * should fill a fixed-aspect container via object-cover. */
  layout?: "constrained" | "full-width" | "none";
}

const {
  src,
  alt,
  class: className,
  width,
  height,
  widths,
  sizes,
  loading = "lazy",
  layout,
} = Astro.props;

const resolved = resolveImage(src);
---

{
  resolved ? (
    <Image
      src={resolved()}
      alt={alt}
      class={className}
      width={width}
      height={height}
      widths={widths}
      sizes={sizes}
      loading={loading}
      layout={layout}
    />
  ) : (
    <img
      src={src}
      alt={alt}
      class={className}
      width={width}
      height={height}
      loading={loading}
    />
  )
}
