---
import { Image } from "astro:assets";
import {
  getLangFromUrl,
  getLocalizedPath,
  useTranslations,
  type Lang,
} from "../i18n";
import heroImage from "../assets/images/hospital_exterior.jpg";

interface Props {
  lang?: Lang;
}

const lang = Astro.props.lang ?? getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<header class="relative h-[85vh] bg-qcBlack flex items-center overflow-hidden">
  <div class="absolute inset-0 z-0">
    <Image
      src={heroImage}
      alt=""
      class="w-full h-full object-cover opacity-70 grayscale-[10%]"
      loading="eager"
      decoding="async"
      fetchpriority="high"
      format="webp"
      quality={70}
      widths={[480, 800, 1200, 1600]}
      sizes="100vw"
    />
    <div
      class="absolute inset-0 bg-gradient-to-r from-qcBlack via-qcBlack/60 to-transparent"
    >
    </div>
  </div>

  <div class="relative z-20 max-w-[1600px] mx-auto px-6 w-full">
    <div class="max-w-3xl">
      <span class="qc-label mb-8">
        {t("hero.foundation")}
      </span>
      <h1
        class="text-5xl md:text-8xl font-bold text-white leading-[0.9] tracking-tighter mb-10"
      >
        {t("hero.subtitlePrefix")}<span class="text-qcRed"
          >{t("hero.subtitleHighlight")}</span
        >.
      </h1>

      <div class="flex flex-wrap gap-6 items-center">
        <button
          class="qc-btn qc-btn--primary px-12 py-5 hover:bg-white hover:text-qcBlack"
        >
          {t("hero.cta1")}
        </button>
        <a
          href={getLocalizedPath("/donate", lang)}
          class="qc-btn group flex items-center text-white hover:text-qcRed"
        >
          <span
            class="w-12 h-12 rounded-full flex items-center justify-center group-hover:border-qcRed transition-colors"
          >
            <i class="fa-solid fa-heart text"></i>
          </span>
          {t("hero.cta2")}
        </a>
      </div>
    </div>
  </div>
</header>
