---
import { getLangFromUrl, useTranslations, type Lang } from "../i18n";

interface Props {
  lang?: Lang;
}

const lang = Astro.props.lang ?? getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<header class="relative h-[85vh] bg-qcBlack flex items-center overflow-hidden">
  <div class="absolute inset-0 z-0">
    <video
      autoplay
      muted
      loop
      playsinline
      class="w-full h-full object-cover opacity-70 grayscale-[10%]"
    >
      <source src="/videos/hero.webm" type="video/webm" />
    </video>
    <div
      class="absolute inset-0 bg-gradient-to-r from-qcBlack via-qcBlack/60 to-transparent"
    >
    </div>
  </div>

  <div class="relative z-20 max-w-[1600px] mx-auto px-6 w-full">
    <div class="max-w-3xl">
      <span class="qc-label mb-8">
        {t("hero.foundation")}
      </span>
      <h1
        class="text-6xl md:text-[7.5rem] font-bold text-white leading-[0.8] tracking-tighter mb-10"
      >
        {t("hero.title1")}<br />
        <span class="text-qcRed">{t("hero.title2")}</span>
      </h1>
      <p class="qc-body--light max-w-lg mb-12 font-light md:text-xl">
        {t("hero.subtitle")}
      </p>

      <div class="flex flex-wrap gap-6 items-center">
        <button
          class="qc-btn qc-btn--primary px-12 py-5 hover:bg-white hover:text-qcBlack"
        >
          {t("hero.cta1")}
        </button>
        <button
          class="qc-btn group flex items-center text-white hover:text-qcRed"
        >
          <span
            class="w-12 h-12 rounded-full flex items-center justify-center group-hover:border-qcRed transition-colors"
          >
            <i class="fa-solid fa-heart text"></i>
          </span>
          {t("hero.cta2")}
        </button>
      </div>
    </div>
  </div>
</header>
