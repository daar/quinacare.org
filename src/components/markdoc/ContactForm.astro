---

<div class="grid lg:grid-cols-5 gap-16 max-w-6xl mx-auto">
  <div class="lg:col-span-2 space-y-8">
    <div>
      <h3 class="text-2xl font-bold text-qcBlack mb-4">{t.contactDetails}</h3>
      <p class="text-gray-500 leading-relaxed">{t.contactIntro}</p>
    </div>

    <div class="space-y-6">
      <a href="mailto:care@quinacare.org" class="flex items-center gap-4 group">
        <div
          class="w-12 h-12 rounded-full bg-qcRed/10 flex items-center justify-center flex-shrink-0 group-hover:bg-qcRed transition-colors duration-300"
        >
          <Icon
            name="envelope"
            class="text-qcRed group-hover:text-white transition-colors duration-300"
          />
        </div>
        <div>
          <p class="text-sm text-gray-400">{t.email}</p>
          <p
            class="font-semibold text-qcBlack group-hover:text-qcRed transition-colors"
          >
            care@quinacare.org
          </p>
        </div>
      </a>

      <a href="tel:+31630366030" class="flex items-center gap-4 group">
        <div
          class="w-12 h-12 rounded-full bg-qcRed/10 flex items-center justify-center flex-shrink-0 group-hover:bg-qcRed transition-colors duration-300"
        >
          <Icon
            name="phone"
            class="text-qcRed group-hover:text-white transition-colors duration-300"
          />
        </div>
        <div>
          <p class="text-sm text-gray-400">{t.phone}</p>
          <p
            class="font-semibold text-qcBlack group-hover:text-qcRed transition-colors"
          >
            +31 6 30 36 60 30
          </p>
        </div>
      </a>

      <div class="flex items-center gap-4">
        <div
          class="w-12 h-12 rounded-full bg-qcRed/10 flex items-center justify-center flex-shrink-0"
        >
          <Icon name="location-dot" class="text-qcRed" />
        </div>
        <div>
          <p class="text-sm text-gray-400">{t.postalAddress}</p>
          <address class="font-semibold text-qcBlack not-italic">
            IJsvogellaan 76, 2261 DK Leidschendam
          </address>
        </div>
      </div>
    </div>

    <div class="pt-4">
      <p class="text-sm text-gray-400 mb-3">{t.followUs}</p>
      <div class="flex gap-3">
        <a
          href="https://facebook.com/quinacare/"
          target="_blank"
          rel="noopener noreferrer"
          class="w-10 h-10 rounded-full bg-gray-100 flex items-center justify-center text-gray-400 hover:bg-qcRed hover:text-white transition-all duration-300"
          aria-label="Facebook"
        >
          <Icon name="facebook" />
        </a>
        <a
          href="https://instagram.com/quinacare/"
          target="_blank"
          rel="noopener noreferrer"
          class="w-10 h-10 rounded-full bg-gray-100 flex items-center justify-center text-gray-400 hover:bg-qcRed hover:text-white transition-all duration-300"
          aria-label="Instagram"
        >
          <Icon name="instagram" />
        </a>
        <a
          href="https://youtube.com/channel/UCyizISjNUBws4KdIIda9K7w"
          target="_blank"
          rel="noopener noreferrer"
          class="w-10 h-10 rounded-full bg-gray-100 flex items-center justify-center text-gray-400 hover:bg-qcRed hover:text-white transition-all duration-300"
          aria-label="YouTube"
        >
          <Icon name="youtube" />
        </a>
        <a
          href="https://www.linkedin.com/company/quina-care/"
          target="_blank"
          rel="noopener noreferrer"
          class="w-10 h-10 rounded-full bg-gray-100 flex items-center justify-center text-gray-400 hover:bg-qcRed hover:text-white transition-all duration-300"
          aria-label="LinkedIn"
        >
          <Icon name="linkedin" />
        </a>
      </div>
    </div>
  </div>

  <form
    class="lg:col-span-3 space-y-6"
    id="contact-form"
    data-msg-from={t.messageFrom}
    data-from={t.from}
  >
    {/* Honeypot — hidden from people and assistive tech; spam bots fill it
        and get silently dropped server-side. Not a real field. */}
    <div class="absolute -left-[9999px] h-px w-px overflow-hidden" aria-hidden="true">
      <label for="company">Company</label>
      <input
        type="text"
        id="company"
        name="company"
        tabindex="-1"
        autocomplete="off"
      />
    </div>

    <div class="grid sm:grid-cols-2 gap-6">
      <div>
        <label for="name" class="block text-sm font-semibold text-qcBlack mb-2"
          >{t.name} *</label
        >
        <input
          type="text"
          id="name"
          name="name"
          required
          class="w-full px-4 py-3 rounded-xl border border-gray-200 bg-white text-qcBlack placeholder-gray-300 focus:outline-none focus:ring-2 focus:ring-qcRed/30 focus:border-qcRed transition-all"
          placeholder={t.namePlaceholder}
        />
      </div>
      <div>
        <label for="email" class="block text-sm font-semibold text-qcBlack mb-2"
          >{t.emailLabel} *</label
        >
        <input
          type="email"
          id="email"
          name="email"
          required
          class="w-full px-4 py-3 rounded-xl border border-gray-200 bg-white text-qcBlack placeholder-gray-300 focus:outline-none focus:ring-2 focus:ring-qcRed/30 focus:border-qcRed transition-all"
          placeholder={t.emailPlaceholder}
        />
      </div>
    </div>

    <div>
      <label for="subject" class="block text-sm font-semibold text-qcBlack mb-2"
        >{t.subject} *</label
      >
      <select
        id="subject"
        name="subject"
        required
        class="w-full px-4 py-3 rounded-xl border border-gray-200 bg-white text-qcBlack focus:outline-none focus:ring-2 focus:ring-qcRed/30 focus:border-qcRed transition-all"
      >
        <option value="" disabled selected>{t.subjectPlaceholder}</option>
        <option value="general">{t.subjectGeneral}</option>
        <option value="volunteer">{t.subjectVolunteer}</option>
        <option value="donate">{t.subjectDonate}</option>
        <option value="cancellation">{t.subjectCancellation}</option>
        <option value="collaboration">{t.subjectCollaboration}</option>
        <option value="press">{t.subjectPress}</option>
        <option value="complaint">{t.subjectComplaint}</option>
        <option value="other">{t.subjectOther}</option>
      </select>
    </div>

    <div>
      <label for="message" class="block text-sm font-semibold text-qcBlack mb-2"
        >{t.message} *</label
      >
      <textarea
        id="message"
        name="message"
        rows="6"
        required
        class="w-full px-4 py-3 rounded-xl border border-gray-200 bg-white text-qcBlack placeholder-gray-300 focus:outline-none focus:ring-2 focus:ring-qcRed/30 focus:border-qcRed transition-all resize-none"
        placeholder={t.messagePlaceholder}></textarea>
    </div>

    <button
      type="submit"
      class="contact-btn qc-btn qc-btn--primary w-full sm:w-auto px-10 py-4 text-base"
    >
      <span class="contact-btn-text"
        ><Icon name="paper-plane" class="mr-2" />{t.send}</span
      >
      <span class="contact-btn-sending !hidden"
        ><Icon name="spinner" class="mr-2 animate-spin" />{t.sending}</span
      >
    </button>

    <p class="contact-error !hidden mt-4 text-sm font-sans text-qcRed">
      {t.error}
    </p>
    <p class="contact-success !hidden mt-4 text-lg font-sans text-green-600">
      {t.success}
    </p>

    <p class="mt-6 text-xs text-gray-500 font-sans">
      {t.privacyNotice}{" "}
      <a
        href={t.privacyPath}
        class="underline decoration-dotted underline-offset-4 text-qcRed hover:decoration-solid"
      >
        {t.privacyLink}
      </a>.
    </p>
  </form>
</div>

<script>
  // Time-trap: when the form was rendered. Real users take seconds to fill
  // it in; bots that auto-submit do so near-instantly and get dropped.
  const loadedAt = Date.now();
  const form = document.getElementById("contact-form") as HTMLFormElement;
  if (form) {
    const btn = form.querySelector<HTMLButtonElement>(".contact-btn")!;
    const btnText = form.querySelector<HTMLElement>(".contact-btn-text")!;
    const btnSending = form.querySelector<HTMLElement>(".contact-btn-sending")!;
    const errorEl = form.querySelector<HTMLElement>(".contact-error")!;
    const successEl = form.querySelector<HTMLElement>(".contact-success")!;

    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      errorEl.classList.add("!hidden");

      const data = new FormData(form);

      btn.disabled = true;
      btnText.classList.add("!hidden");
      btnSending.classList.remove("!hidden");

      try {
        const res = await fetch("/api/contact/send", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            name: data.get("name"),
            email: data.get("email"),
            subject: data.get("subject"),
            message: data.get("message"),
            company: data.get("company"), // honeypot (should be empty)
            elapsedMs: Date.now() - loadedAt, // time-trap
          }),
        });

        if (!res.ok) {
          errorEl.classList.remove("!hidden");
          return;
        }

        form.reset();
        btn.classList.add("!hidden");
        successEl.classList.remove("!hidden");
      } catch {
        errorEl.classList.remove("!hidden");
      } finally {
        btn.disabled = false;
        btnText.classList.remove("!hidden");
        btnSending.classList.add("!hidden");
      }
    });
  }
</script>
