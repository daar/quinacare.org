---
import { Image } from "astro:assets";
import { resolveImage } from "../../lib/images";

interface Props {
  src: string;
  alt?: string;
}

const { src, alt = "" } = Astro.props;

const resolver = resolveImage(src);
const meta = resolver ? (await resolver()).default : null;
---

<swiper-slide class="qc-gallery__slide">
  {
    meta ? (
      <Image
        src={meta}
        alt={alt}
        class="qc-gallery__img"
        widths={[640, 1024, 1600]}
        sizes="(max-width: 768px) 100vw, 800px"
      />
    ) : (
      <img class="qc-gallery__img" src={src} alt={alt} loading="lazy" />
    )
  }
</swiper-slide>
