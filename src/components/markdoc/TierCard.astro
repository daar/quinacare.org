---
import OptimizedImage from "../OptimizedImage.astro";

interface Props {
  image: string;
  title: string;
  price: string;
  frequency: string;
  impact: string;
  yearly: string;
  href: string;
  featured?: boolean;
}

const {
  image,
  title,
  price,
  frequency,
  impact,
  yearly,
  href,
  featured = false,
} = Astro.props;
---

<div
  class={`group border p-8 md:p-10 transition-all duration-500 relative overflow-hidden rounded-xl flex flex-col items-center text-center ${featured ? "border-qcRed bg-red-50/30 scale-[1.02] shadow-lg" : "border-gray-100 hover:border-qcRed"}`}
>
  <div class="w-32 h-32 mb-6 relative">
    <OptimizedImage
      src={image}
      alt={title}
      width={128}
      height={128}
      class="w-full h-full object-contain drop-shadow-lg"
    />
  </div>

  <h3 class="text-xl font-bold uppercase tracking-tight mb-2">{title}</h3>

  <div class="mb-4">
    <span class="text-qcRed font-bold text-4xl tracking-tighter">{price}</span>
    <span class="text-gray-400 text-sm block">{frequency}</span>
  </div>

  <p class="qc-body leading-relaxed mb-2 min-h-[3rem]">
    {impact}
  </p>

  <span class="qc-meta mb-6">
    {yearly}
  </span>

  <button
    type="button"
    data-open-modal="sponsor-modal"
    data-amount={href.match(/amount=(\d+)/)?.[1] || ""}
    data-card-type={title.toLowerCase().replace(/\s+/g, "-")}
    class={`qc-btn block w-full py-3.5 text-center ${
      featured ? "qc-btn--primary" : "qc-btn--outline"
    }`}
  >
    <i class="fa-solid fa-heart mr-2"></i>
    {title}
  </button>
</div>
