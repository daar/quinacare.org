---
interface Props {
  variant: "info" | "social";
}

const { variant } = Astro.props;
---

{
  variant === "info" ? (
    <div class="grid md:grid-cols-3 gap-0 max-w-5xl mx-auto rounded-2xl overflow-hidden border border-gray-100 shadow-sm">
      <a
        href="mailto:care@quinacare.org"
        class="group relative bg-white p-10 flex flex-col items-center text-center hover:bg-qcRed transition-all duration-500 border-b md:border-b-0 md:border-r border-gray-100"
      >
        <div class="w-16 h-16 rounded-full bg-qcRed/10 group-hover:bg-white/20 flex items-center justify-center mb-6 transition-colors duration-500">
          <i class="fa-solid fa-envelope text-qcRed group-hover:text-white text-2xl transition-colors duration-500" />
        </div>
        <h3 class="text-xl font-bold text-qcBlack group-hover:text-white mb-2 transition-colors duration-500">
          E-mail
        </h3>
        <p class="text-sm text-gray-400 group-hover:text-white/70 mb-4 transition-colors duration-500">
          Voor algemene vragen en informatie
        </p>
        <span class="text-qcRed group-hover:text-white font-semibold transition-colors duration-500">
          care@quinacare.org
        </span>
      </a>

      <a
        href="tel:+31641357796"
        class="group relative bg-white p-10 flex flex-col items-center text-center hover:bg-qcRed transition-all duration-500 border-b md:border-b-0 md:border-r border-gray-100"
      >
        <div class="w-16 h-16 rounded-full bg-qcRed/10 group-hover:bg-white/20 flex items-center justify-center mb-6 transition-colors duration-500">
          <i class="fa-solid fa-phone text-qcRed group-hover:text-white text-2xl transition-colors duration-500" />
        </div>
        <h3 class="text-xl font-bold text-qcBlack group-hover:text-white mb-2 transition-colors duration-500">
          Telefoon
        </h3>
        <p class="text-sm text-gray-400 group-hover:text-white/70 mb-4 transition-colors duration-500">
          Nederland
        </p>
        <span class="text-qcRed group-hover:text-white font-semibold transition-colors duration-500">
          +31 6 41 35 77 96
        </span>
      </a>

      <div class="group relative bg-white p-10 flex flex-col items-center text-center">
        <div class="w-16 h-16 rounded-full bg-qcRed/10 flex items-center justify-center mb-6">
          <i class="fa-solid fa-location-dot text-qcRed text-2xl" />
        </div>
        <h3 class="text-xl font-bold text-qcBlack mb-2">Postadres</h3>
        <p class="text-sm text-gray-400 mb-4">
          Alleen postadres, geen bezoekadres
        </p>
        <address class="text-gray-700 not-italic leading-relaxed font-semibold">
          IJsvogellaan 76
          <br />
          2261 DK Leidschendam
          <br />
          Nederland
        </address>
      </div>
    </div>
  ) : (
    <div class="flex items-center justify-center gap-6">
      <a
        href="https://facebook.com/quinacare/"
        target="_blank"
        rel="noopener noreferrer"
        class="w-12 h-12 rounded-full bg-white/10 flex items-center justify-center text-white/40 hover:text-white hover:bg-white/20 transition-all duration-300"
        aria-label="Facebook"
      >
        <i class="fa-brands fa-facebook text-xl" />
      </a>
      <a
        href="https://instagram.com/quinacare/"
        target="_blank"
        rel="noopener noreferrer"
        class="w-12 h-12 rounded-full bg-white/10 flex items-center justify-center text-white/40 hover:text-white hover:bg-white/20 transition-all duration-300"
        aria-label="Instagram"
      >
        <i class="fa-brands fa-instagram text-xl" />
      </a>
      <a
        href="https://youtube.com/channel/UCyizISjNUBws4KdIIda9K7w"
        target="_blank"
        rel="noopener noreferrer"
        class="w-12 h-12 rounded-full bg-white/10 flex items-center justify-center text-white/40 hover:text-white hover:bg-white/20 transition-all duration-300"
        aria-label="YouTube"
      >
        <i class="fa-brands fa-youtube text-xl" />
      </a>
      <a
        href="https://www.linkedin.com/company/quina-care/"
        target="_blank"
        rel="noopener noreferrer"
        class="w-12 h-12 rounded-full bg-white/10 flex items-center justify-center text-white/40 hover:text-white hover:bg-white/20 transition-all duration-300"
        aria-label="LinkedIn"
      >
        <i class="fa-brands fa-linkedin text-xl" />
      </a>
    </div>
  )
}
