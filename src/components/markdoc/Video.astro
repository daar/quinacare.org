---
interface Props {
  src: string;
  poster?: string;
}

const { src, poster } = Astro.props;
---

<div class="relative rounded-xl overflow-hidden my-8">
  <video
    controls
    preload="metadata"
    poster={poster}
    class="w-full aspect-video bg-black"
  >
    <source src={src} type="video/mp4" />
  </video>
</div>
