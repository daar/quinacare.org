---
interface Props {
  src: string;
  poster?: string;
}

const { src, poster } = Astro.props;

// Resolve poster images referenced as "/media/..." or "/images/..." to the
// bundled asset in src/assets. External URLs and any other path pass through
// unchanged. The glob is lazy, so only the assets actually used get emitted.
//
// Videos are NOT bundled: large files routed through Vite's ?url pipeline get
// read into memory at build time and OOM-kill the build. They live in
// public/video/... instead and are served verbatim, so "/video/..." paths
// fall through here untouched.
const localAssets = import.meta.glob<string>(
  "/src/assets/**/*.{jpg,jpeg,png,webp,gif,avif}",
  { query: "?url", import: "default" },
);
async function resolveAsset(value?: string): Promise<string | undefined> {
  if (!value || !/^\/(media|images)\//.test(value)) return value;
  const loader = localAssets[`/src/assets${value}`];
  return loader ? await loader() : value;
}
const resolvedSrc = await resolveAsset(src);
const resolvedPoster = await resolveAsset(poster);

const ext = (src.split(".").pop() || "mp4").toLowerCase();
const mimeType =
  ext === "webm" ? "video/webm" : ext === "ogg" ? "video/ogg" : "video/mp4";
---

<div class="relative rounded-xl overflow-hidden my-8">
  <video
    controls
    preload="metadata"
    poster={resolvedPoster}
    class="w-full aspect-video bg-black"
  >
    <source src={resolvedSrc} type={mimeType} />
  </video>
</div>
