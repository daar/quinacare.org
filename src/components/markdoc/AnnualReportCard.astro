---
import ReportCard from "../ReportCard.astro";
import { annualReports } from "../../data/annualReports";

interface Props {
  /** Report year to embed. */
  year: number;
  /** "nl" | "en" | "es". */
  lang: string;
}

const { year, lang } = Astro.props;
const key = (["nl", "en", "es"].includes(lang) ? lang : "nl") as
  | "nl"
  | "en"
  | "es";

const labels: Record<"nl" | "en" | "es", { report: string; download: string }> =
  {
    nl: { report: "Jaarverslag", download: "Download pdf" },
    en: { report: "Annual report", download: "Download pdf" },
    es: { report: "Informe anual", download: "Descargar pdf" },
  };
const l = labels[key];

const report = annualReports.find((r) => r.year === year);
const href = report?.files[key];
const cover = report?.covers[key];
---

{
  href && (
    <div class="not-prose my-8 w-44">
      <ReportCard
        href={href}
        cover={cover}
        label={l.report}
        title={String(year)}
        downloadLabel={l.download}
      />
    </div>
  )
}
