---
interface Props {
  title: string;
  icon: string;
  href?: string;
}

const { title, icon, href } = Astro.props;
const Tag = href ? "a" : "div";
---

<Tag
  {...href ? { href } : {}}
  class="group bg-white border border-gray-100 rounded-2xl p-10 text-center hover:shadow-xl hover:border-qcRed/20 transition-all duration-500"
>
  <div
    class="w-16 h-16 rounded-full bg-qcRed/10 group-hover:bg-qcRed flex items-center justify-center mx-auto mb-6 transition-colors duration-500"
  >
    <i
      class:list={[
        icon,
        "text-2xl text-qcRed group-hover:text-white transition-colors duration-500",
      ]}></i>
  </div>
  <h3 class="text-xl font-bold text-qcBlack mb-3">{title}</h3>
  <div class="text-gray-500 leading-relaxed">
    <slot />
  </div>
</Tag>
