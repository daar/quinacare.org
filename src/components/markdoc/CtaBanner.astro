---
interface Props {
  title: string;
  subtitle?: string;
  cta: string;
  href: string;
}

const { title, subtitle, cta, href } = Astro.props;
---

<section class="relative bg-qcRed py-24 overflow-hidden">
  <div class="absolute inset-0 opacity-10 pointer-events-none">
    <svg class="w-full h-full" viewBox="0 0 100 100" preserveAspectRatio="none">
      <path d="M0 100 L100 0 L100 100 Z" fill="black"></path>
    </svg>
  </div>

  <div class="max-w-7xl mx-auto px-6 relative z-10">
    <div class="flex flex-col lg:flex-row items-center justify-between gap-12">
      <div class="text-white text-center lg:text-left">
        <h2
          class="text-4xl md:text-6xl font-bold tracking-tighter uppercase leading-[0.9] mb-6"
        >
          {title}
        </h2>
        {
          subtitle && (
            <p class="qc-body max-w-md font-light !text-red-100">{subtitle}</p>
          )
        }
      </div>

      <div class="flex-shrink-0">
        <a
          href={href}
          class="qc-btn qc-btn--white group relative inline-flex items-center gap-6 px-10 py-6 shadow-2xl shadow-red-900/20 duration-500"
        >
          <i
            class="fa-solid fa-heart transition-transform group-hover:scale-125"
          ></i>
          <span>{cta}</span>
        </a>

        <div
          class="mt-4 flex items-center justify-center lg:justify-start gap-4 text-red-200 text-[9px] font-bold uppercase tracking-widest opacity-70"
        >
          <span class="flex items-center gap-1">
            <i class="fa-solid fa-lock"></i>
            ANBI
          </span>
          <span class="flex items-center gap-1">
            <i class="fa-solid fa-certificate"></i>
            CBF
          </span>
        </div>
      </div>
    </div>
  </div>
</section>
