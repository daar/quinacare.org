---
import {
  getLangFromUrl,
  useTranslations,
  getLocalizedPath,
  type Lang,
} from "../i18n";
import { donationTiers } from "../lib/donationTiers";
import { getCurrency, formatCurrency } from "../lib/currency";

interface Props {
  lang?: Lang;
}

const lang = Astro.props.lang ?? getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const cc = getCurrency(lang);
---

<section class="py-24 bg-white border-b border-gray-100">
  <div class="max-w-7xl mx-auto px-6">
    <div class="text-center mb-16">
      <span class="qc-label mb-4">{t("donation.directImpact")}</span>
      <h2 class="text-4xl font-bold tracking-tighter uppercase mb-4">
        {t("donation.title")}
      </h2>
      <p class="qc-body max-w-xl mx-auto leading-relaxed">
        {t("donation.subtitle")}
      </p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
      {
        donationTiers.map((tier) => {
          const copy = tier.i18n[lang];
          const amountLabel = formatCurrency(tier.amount, cc, false);
          return (
            <div class="group flex flex-col bg-white border border-qcBlack p-8 hover:border-qcRed transition-all duration-500 relative overflow-hidden rounded-md">
              <div class="absolute top-0 right-0 p-4 opacity-5 group-hover:opacity-10 transition-opacity">
                <i class={`${tier.icon} text-6xl`} />
              </div>
              <h3 class="text-qcBlack group-hover:text-qcRed transition-colors duration-500 font-bold text-5xl tracking-tighter mb-6">
                {amountLabel}
              </h3>
              <h4 class="text-qcBlack group-hover:text-qcRed transition-colors duration-500 text-lg font-bold uppercase tracking-tight mb-4">
                {copy.title}
              </h4>
              <p class="text-lg leading-relaxed mb-8 text-qcBlack group-hover:text-qcRed transition-colors duration-500">
                {copy.description}
              </p>
              <a
                href={`${getLocalizedPath("/donate", lang)}?amount=${tier.amount}`}
                target="_blank"
                rel="noopener noreferrer"
                class="qc-btn block w-full py-3 text-center mt-auto rounded-md bg-white border border-qcBlack text-qcBlack group-hover:border-qcRed group-hover:text-qcRed"
              >
                {t("donation.donate")} {amountLabel}
              </a>
            </div>
          );
        })
      }
    </div>

    <div class="mt-16 text-center">
      <a
        href={`${getLocalizedPath("/donate", lang)}?custom=1`}
        target="_blank"
        rel="noopener noreferrer"
        class="qc-btn qc-btn--ghost text-gray-400"
      >
        {t("donation.chooseAmount")}
        <i class="fa-solid fa-chevron-right ml-2 text-[8px]"></i>
      </a>
    </div>
  </div>
</section>
