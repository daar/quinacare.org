---
import {
  getLangFromUrl,
  useTranslations,
  getLocalizedPath,
  type Lang,
} from "../i18n";

interface Props {
  lang?: Lang;
}

const lang = Astro.props.lang ?? getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section class="py-24 bg-white border-b border-gray-100">
  <div class="max-w-7xl mx-auto px-6">
    <div class="text-center mb-16">
      <span class="qc-label mb-4">{t("donation.directImpact")}</span>
      <h2 class="text-4xl font-bold tracking-tighter uppercase mb-4">
        {t("donation.title")}
      </h2>
      <p class="qc-body max-w-xl mx-auto leading-relaxed">
        {t("donation.subtitle")}
      </p>
    </div>

    <div class="grid md:grid-cols-3 gap-8">
      <div
        class="group border border-gray-100 p-10 hover:border-qcRed transition-all duration-500 relative overflow-hidden rounded-md"
      >
        <div
          class="absolute top-0 right-0 p-4 opacity-5 group-hover:opacity-10 transition-opacity"
        >
          <i class="fa-solid fa-pills text-6xl"></i>
        </div>
        <h3 class="text-qcRed font-bold text-5xl tracking-tighter mb-6">€15</h3>
        <h4 class="text-lg font-bold uppercase tracking-tight mb-4">
          {t("donation.medication")}
        </h4>
        <p class="qc-body leading-relaxed mb-8">
          {t("donation.medicationDesc")}
        </p>
        <a
          href={`${getLocalizedPath("/donate", lang)}?amount=15`}
          class="qc-btn qc-btn--outline block w-full py-3 text-center"
        >
          {t("donation.donate")} &euro;15
        </a>
      </div>

      <div
        class="group border border-gray-100 p-10 hover:border-qcRed transition-all duration-500 relative overflow-hidden bg-qcGray/30 rounded-md"
      >
        <div
          class="absolute top-0 right-0 p-4 opacity-5 group-hover:opacity-10 transition-opacity"
        >
          <i class="fa-solid fa-baby text-6xl"></i>
        </div>
        <h3 class="text-qcRed font-bold text-5xl tracking-tighter mb-6">€35</h3>
        <h4 class="text-lg font-bold uppercase tracking-tight mb-4">
          {t("donation.prenatal")}
        </h4>
        <p class="qc-body leading-relaxed mb-8">
          {t("donation.prenatalDesc")}
        </p>
        <a
          href={`${getLocalizedPath("/donate", lang)}?amount=35`}
          class="qc-btn qc-btn--secondary block w-full py-3 text-center"
        >
          {t("donation.donate")} &euro;35
        </a>
      </div>

      <div
        class="group border border-gray-100 p-10 hover:border-qcRed transition-all duration-500 relative overflow-hidden rounded-md"
      >
        <div
          class="absolute top-0 right-0 p-4 opacity-5 group-hover:opacity-10 transition-opacity"
        >
          <i class="fa-solid fa-stethoscope text-6xl"></i>
        </div>
        <h3 class="text-qcRed font-bold text-5xl tracking-tighter mb-6">€75</h3>
        <h4 class="text-lg font-bold uppercase tracking-tight mb-4">
          {t("donation.surgery")}
        </h4>
        <p class="qc-body leading-relaxed mb-8">
          {t("donation.surgeryDesc")}
        </p>
        <a
          href={`${getLocalizedPath("/donate", lang)}?amount=75`}
          class="qc-btn qc-btn--outline block w-full py-3 text-center"
        >
          {t("donation.donate")} &euro;75
        </a>
      </div>
    </div>

    <div class="mt-16 text-center">
      <a
        href={getLocalizedPath("/donate", lang)}
        class="qc-btn qc-btn--ghost text-gray-400"
      >
        {t("donation.chooseAmount")}
        <i class="fa-solid fa-chevron-right ml-2 text-[8px]"></i>
      </a>
    </div>
  </div>
</section>
