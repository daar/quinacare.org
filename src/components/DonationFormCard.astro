---
// DonationFormCard — the one donation widget used by every page that
// asks for money (the /donate page, fundraiser detail pages, the
// Putumayo Loop landing page, …).
//
// All variation between pages is expressed through flat props.
// Defaults match the historic /donate-page behaviour so callers that
// pass no overrides get the original widget.
//
// Backend: posts to /api/mollie/create-payment with whatever
// `metadata` the caller supplied. Use the `context` prop to tag the
// donation in the DB ("donate" | "fundraiser"); getFundraiserStats
// reads that column.

import Icon from "./Icon.astro";
import {
  getLangFromUrl,
  useTranslations,
  type Lang,
  type TranslationKey,
} from "../i18n";
import {
  currencies,
  paymentMethodsByLocale,
  getCurrency,
  formatCurrency,
} from "../lib/currency";

type Frequency = "one-time" | "monthly" | "quarterly" | "yearly";

const FREQUENCY_LABEL_KEYS: Record<Frequency, string> = {
  "one-time": "donate.oneTime",
  monthly: "donate.monthly",
  quarterly: "donate.quarterly",
  yearly: "donate.yearly",
};

type ImpactConfig =
  | { kind: "tiered" }
  | {
      kind: "fundraiser";
      organizer?: string;
      excerpt?: string;
      fallback?: string;
    }
  | { kind: "custom"; label?: string; body: string }
  | { kind: "none" };

interface Props {
  lang?: Lang;

  /** Preset amount buttons. Defaults to the locale's currency presets. */
  presets?: number[];
  /** Pre-selected amount. Defaults to presets[1] (the second preset). */
  defaultAmount?: number;
  /** Whether to show the free-text "other amount" input. Default true. */
  allowCustom?: boolean;

  /**
   * Which frequencies the page wants to offer. A single-frequency list
   * hides the toggle entirely. Default: both ["one-time", "monthly"].
   */
  frequencies?: Frequency[];
  /** Default selected frequency. Default "one-time". */
  defaultFrequency?: Frequency;

  /**
   * Payment methods to expose. Defaults to paymentMethodsByLocale for
   * the locale. Pages can pin a smaller list (e.g. only iDEAL + Card).
   */
  methods?: string[];

  /** How the impact preview renders. Default { kind: "tiered" }. */
  impact?: ImpactConfig;

  /**
   * sessionStorage namespace. Default `donate:${context}`. Pass a
   * page-specific id ("fundraiser:slug-here", "putumayo:2026") so each
   * page restores its OWN last-picked amount / method.
   */
  scopeId?: string;

  /**
   * Tag for the donation row in the DB. "fundraiser" rows are picked
   * up by getFundraiserStats when their metadata.fundraiser_slug
   * matches. "yura-boom" is used by the Quina Yura sponsor flow so
   * the row can be filtered separately from generic /donate gifts.
   * Default "donate".
   */
  context?: "donate" | "fundraiser" | "yura-boom";

  /** Arbitrary metadata forwarded to Mollie + the donations row. */
  metadata?: Record<string, unknown>;

  /**
   * Optional override for the Mollie payment description (shown to the
   * donor in their bank/payment app). When set, the API uses this
   * verbatim instead of the auto-built "<fundraiser> - donation €X"
   * form, so short campaign names like "Putumayo Loop 2026" survive
   * the ~22-char card-statement truncation.
   */
  description?: string;
}

const {
  lang: langProp,
  presets,
  defaultAmount,
  allowCustom = true,
  frequencies = ["one-time", "monthly"] as Frequency[],
  defaultFrequency = "one-time" as Frequency,
  methods,
  impact = { kind: "tiered" } as ImpactConfig,
  scopeId,
  context = "donate",
  metadata = {},
  description,
} = Astro.props;

const lang = langProp ?? getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const cc = getCurrency(lang);

// Resolve effective config (props win over locale defaults)
const effectivePresets = presets ?? cc.presets;
const effectiveDefaultAmount =
  defaultAmount ?? effectivePresets[1] ?? effectivePresets[0] ?? 50;
const effectiveMethods = methods ?? paymentMethodsByLocale[lang] ?? ["card"];
const effectiveScopeId = scopeId ?? `donate:${context}`;
const showFrequencyToggle = frequencies.length > 1;
---

<div
  class="donation-form-card"
  data-context={context}
  data-scope-id={effectiveScopeId}
  data-currencies={JSON.stringify(currencies)}
  data-methods={JSON.stringify(effectiveMethods)}
  data-frequencies={JSON.stringify(frequencies)}
  data-default-frequency={defaultFrequency}
  data-default-amount={effectiveDefaultAmount}
  data-allow-custom={allowCustom ? "1" : "0"}
  data-metadata={JSON.stringify(metadata)}
  data-description={description ?? ""}
>
  <h2 class="text-2xl font-bold tracking-tighter uppercase mb-6 text-center">
    {t("donate.submitButton")}
  </h2>

  {
    /* Optional cause card — populated and revealed when the form is
      opened from a tier-style modal trigger that carries
      data-cause-title / data-cause-image / data-cause-impact. */
  }
  <div
    class="dfc-cause hidden mb-6 flex items-center gap-4 rounded-xl border border-gray-100 bg-gray-50 p-4"
  >
    <img
      alt=""
      class="dfc-cause-image h-16 w-16 flex-shrink-0 object-contain"
    />
    <div class="min-w-0 flex-1">
      <p
        class="dfc-cause-title font-bold uppercase tracking-tight text-sm leading-tight"
      >
      </p>
      <p class="dfc-cause-impact qc-meta mt-1 leading-snug"></p>
    </div>
  </div>

  {
    showFrequencyToggle && (
      <div class="flex gap-2 mb-6 dfc-frequency">
        {frequencies.map((f) => (
          <button
            type="button"
            data-frequency={f}
            class="qc-btn flex-1 py-3 rounded-md border border-gray-200 bg-white text-qcBlack"
          >
            {t(FREQUENCY_LABEL_KEYS[f] as TranslationKey)}
          </button>
        ))}
      </div>
    )
  }

  <!-- Preset amounts -->
  <div class="grid grid-cols-4 gap-2 mb-2 dfc-amounts">
    {
      effectivePresets.map((amount) => (
        <button
          type="button"
          data-amount={amount}
          class:list={[
            "py-3 text-center font-bold text-base rounded-md border transition-all",
            amount === effectiveDefaultAmount
              ? "bg-qcRed text-white border-qcRed"
              : "bg-white text-qcBlack border-gray-200 hover:border-qcRed",
          ]}
        >
          {formatCurrency(amount, cc, false)}
        </button>
      ))
    }
  </div>

  {
    allowCustom && (
      <input
        type="text"
        inputmode="decimal"
        class="dfc-custom w-full py-3 px-4 text-center font-bold text-base rounded-md border border-gray-200 focus:border-qcRed focus:outline-none transition-all mb-6"
        placeholder={t("donate.customPlaceholder")}
      />
    )
  }

  <!-- Impact preview — kind drives the panel shape -->
  {
    impact.kind === "tiered" && (
      <div class="bg-gray-50 border border-gray-100 rounded-md p-4 mb-6">
        <span class="qc-label mb-1">{t("donate.impactLabel")}</span>
        <p class="dfc-impact qc-body leading-relaxed">
          {t("donate.impactGeneric")}
        </p>
        <span class="hidden" data-impact="consultation">
          {t("donation.consultationDesc")}
        </span>
        <span class="hidden" data-impact="prenatal">
          {t("donation.prenatalDesc")}
        </span>
        <span class="hidden" data-impact="surgery">
          {t("donation.surgeryDesc")}
        </span>
        <span class="hidden" data-impact="equipment">
          {t("donation.equipmentDesc")}
        </span>
        <span class="hidden" data-impact="generic">
          {t("donate.impactGeneric")}
        </span>
      </div>
    )
  }
  {
    impact.kind === "fundraiser" && (
      <div class="bg-gray-50 border border-gray-100 rounded-md p-4 mb-6">
        <p class="qc-body leading-relaxed">
          {t("fundraise.impactLabel")}{" "}
          <span class="font-bold text-qcRed">
            {impact.organizer || impact.fallback || ""}
          </span>
          {impact.excerpt && (
            <>
              {" — "}
              <em>“{impact.excerpt}”</em>
            </>
          )}
        </p>
      </div>
    )
  }
  {
    impact.kind === "custom" && (
      <div class="bg-gray-50 border border-gray-100 rounded-md p-4 mb-6">
        {impact.label && <span class="qc-label mb-1">{impact.label}</span>}
        <p class="qc-body leading-relaxed">{impact.body}</p>
      </div>
    )
  }

  <!-- Payment methods (all rendered; JS hides the ones not in `methods`) -->
  <div class="mb-6">
    <span
      class="text-[9px] font-bold uppercase tracking-[0.4em] text-gray-400 block mb-3"
    >
      {t("donate.paymentMethod")}
    </span>
    <div class="grid grid-cols-2 gap-2 dfc-methods">
      <button
        type="button"
        data-method="ideal"
        class="flex items-center justify-center gap-2 py-3 px-3 rounded-md border border-gray-200 bg-white text-xs font-bold transition-all"
      >
        <svg
          class="w-4 h-4"
          viewBox="0 0 24 24"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
        >
          <rect
            x="2"
            y="4"
            width="20"
            height="16"
            rx="2"
            stroke="currentColor"
            stroke-width="2"></rect>
          <path d="M7 12h10M7 8h6" stroke="currentColor" stroke-width="2"
          ></path>
        </svg>
        iDEAL
      </button>
      <button
        type="button"
        data-method="card"
        class="flex items-center justify-center gap-2 py-3 px-3 rounded-md border border-gray-200 bg-white text-xs font-bold transition-all"
      >
        <Icon name="credit-card" />
        {t("donate.creditCard")}
      </button>
      <button
        type="button"
        data-method="paypal"
        class="flex items-center justify-center gap-2 py-3 px-3 rounded-md border border-gray-200 bg-white text-xs font-bold transition-all"
      >
        <Icon name="paypal" />
        PayPal
      </button>
      <button
        type="button"
        data-method="googlepay"
        class="flex items-center justify-center gap-2 py-3 px-3 rounded-md border border-gray-200 bg-white text-xs font-bold transition-all"
      >
        <Icon name="google-pay" class="text-base" />
        Google Pay
      </button>
    </div>
  </div>

  <!-- Submit -->
  <button type="button" class="dfc-submit qc-btn qc-btn--primary w-full py-4">
    <Icon name="heart" class="dfc-icon mr-2" />
    <span
      >{t("donate.submitButton")}
      <span class="dfc-amount"
        >{formatCurrency(effectiveDefaultAmount, cc, false)}</span
      ></span
    >
  </button>

  <!-- Trust badges -->
  <div
    class="mt-4 flex items-center justify-center gap-4 text-[9px] font-bold uppercase tracking-widest text-gray-400"
  >
    <span class="flex items-center gap-1"
      ><Icon name="lock" /> {t("cta.securePayment")}</span
    >
    <span class="flex items-center gap-1"
      ><Icon name="shield-halved" /> SSL</span
    >
  </div>
</div>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    document
      .querySelectorAll<HTMLElement>(".donation-form-card")
      .forEach((card) => {
        interface CurrencyConfig {
          symbol: string;
          precision: number;
          thousand: string;
          decimal: string;
          pattern: string;
          presets: number[];
        }

        const allCurrencies: Record<string, CurrencyConfig> = JSON.parse(
          card.dataset.currencies || "{}",
        );
        const methodsAllowed: string[] = JSON.parse(
          card.dataset.methods || "[]",
        );
        const frequenciesAllowed: string[] = JSON.parse(
          card.dataset.frequencies || '["one-time","monthly"]',
        );
        const metadata: Record<string, unknown> = JSON.parse(
          card.dataset.metadata || "{}",
        );
        const descriptionOverride = card.dataset.description || "";
        const context = card.dataset.context || "donate";
        const scopeId = card.dataset.scopeId || `donate:${context}`;
        const defaultFrequency =
          card.dataset.defaultFrequency || frequenciesAllowed[0] || "one-time";
        const defaultAmount = Number(card.dataset.defaultAmount) || 50;
        const allowCustom = card.dataset.allowCustom !== "0";

        const locale = document.documentElement.lang || "nl";
        const cc = allCurrencies[locale] || allCurrencies.en;

        function fmt(n: number, decimals = false): string {
          const prec = decimals ? cc.precision : 0;
          const fixed = Math.abs(n).toFixed(prec);
          const [intPart, decPart] = fixed.split(".");
          const grouped = intPart.replace(/\B(?=(\d{3})+(?!\d))/g, cc.thousand);
          const value =
            prec > 0 && decPart ? `${grouped}${cc.decimal}${decPart}` : grouped;
          return cc.pattern.replace("%s", cc.symbol).replace("%v", value);
        }

        function parse(input: string): number {
          const cleaned = input
            .replace(cc.symbol, "")
            .replaceAll(cc.thousand, "")
            .replace(cc.decimal, ".")
            .replace(/[^\d.]/g, "")
            .trim();
          const n = parseFloat(cleaned);
          return isNaN(n) ? 0 : Math.floor(n);
        }

        const amountGrid = card.querySelector<HTMLElement>(".dfc-amounts")!;
        const customInput = card.querySelector<HTMLInputElement>(".dfc-custom");
        const freqToggle = card.querySelector<HTMLElement>(".dfc-frequency");
        const methodsEl = card.querySelector<HTMLElement>(".dfc-methods")!;
        const submitBtn = card.querySelector<HTMLButtonElement>(".dfc-submit")!;
        const submitAmount = card.querySelector<HTMLElement>(".dfc-amount")!;
        const impactText = card.querySelector<HTMLElement>(".dfc-impact");
        const submitIcon = card.querySelector<HTMLElement>(".dfc-icon")!;

        let frequency: string = defaultFrequency;
        let amount: number = defaultAmount;
        let method: string = methodsAllowed[0] || "card";

        // Session restore — frequency/method only. Amount always falls
        // back to the page's default so a fresh visit isn't surprised.
        const storageKey = `donate:${scopeId}`;
        const saved = sessionStorage.getItem(storageKey);
        if (saved) {
          try {
            const s = JSON.parse(saved);
            if (s.frequency && frequenciesAllowed.includes(s.frequency))
              frequency = s.frequency;
            if (s.method && methodsAllowed.includes(s.method))
              method = s.method;
          } catch {
            /* ignore */
          }
        }

        // Query-param overrides — useful for direct CTA links like
        //   /donate?amount=100 or /donate?custom=1
        const params = new URLSearchParams(window.location.search);
        const paramAmount = parseInt(params.get("amount") || "", 10);
        if (paramAmount > 0) {
          amount = paramAmount;
          if (
            customInput &&
            !amountGrid.querySelector(`[data-amount="${paramAmount}"]`)
          ) {
            customInput.value = fmt(paramAmount);
          }
        }

        // When the form is mounted inside a <dialog> that fires the
        // shared `modal-open` event (DonationModal does this), let each
        // trigger pin the per-month amount, swap in a cause card with
        // the tier illustration + impact text, and tag the donation
        // row with the tier id. The amount controls hide while a
        // locked amount is in effect so the donor can't override what
        // the tier card promised — they only pick frequency + method.
        // The submit total auto-scales with the frequency they pick:
        // quarterly = 3 × monthly, yearly = 12 × monthly.
        const FREQUENCY_MULTIPLIER: Record<string, number> = {
          "one-time": 1,
          monthly: 1,
          quarterly: 3,
          yearly: 12,
        };
        function scaleAmount(): number {
          const mult = FREQUENCY_MULTIPLIER[frequency] ?? 1;
          return lockedMonthlyAmount !== null
            ? lockedMonthlyAmount * mult
            : amount;
        }

        let lockedMonthlyAmount: number | null = null;

        const causeCard = card.querySelector<HTMLElement>(".dfc-cause");
        const causeImage =
          card.querySelector<HTMLImageElement>(".dfc-cause-image");
        const causeTitle = card.querySelector<HTMLElement>(".dfc-cause-title");
        const causeImpact =
          card.querySelector<HTMLElement>(".dfc-cause-impact");

        const hostDialog = card.closest<HTMLDialogElement>("dialog");
        if (hostDialog) {
          hostDialog.addEventListener("modal-open", (rawEvt: Event) => {
            const detail =
              (rawEvt as CustomEvent<Record<string, string | undefined>>)
                .detail || {};
            const lockedAmount = parseFloat(detail.amount ?? "");
            if (Number.isFinite(lockedAmount) && lockedAmount > 0) {
              lockedMonthlyAmount = lockedAmount;
              amount = lockedAmount * (FREQUENCY_MULTIPLIER[frequency] ?? 1);
              amountGrid.classList.add("hidden");
              customInput?.classList.add("hidden");
              if (impactText)
                (impactText.parentElement as HTMLElement | null)?.classList.add(
                  "hidden",
                );
            } else {
              lockedMonthlyAmount = null;
              amountGrid.classList.remove("hidden");
              customInput?.classList.remove("hidden");
              if (impactText)
                (
                  impactText.parentElement as HTMLElement | null
                )?.classList.remove("hidden");
            }
            if (detail.tier) {
              (metadata as Record<string, unknown>).tier = detail.tier;
            }

            // Populate + reveal the cause card if the trigger carried
            // cause-* fields; hide it otherwise (back to plain form).
            const causeTitleText = detail.causeTitle ?? "";
            const causeImageSrc = detail.causeImage ?? "";
            const causeImpactText = detail.causeImpact ?? "";
            if (causeCard) {
              if (causeTitleText || causeImageSrc || causeImpactText) {
                if (causeTitle) causeTitle.textContent = causeTitleText;
                if (causeImpact) causeImpact.textContent = causeImpactText;
                if (causeImage && causeImageSrc) {
                  causeImage.src = causeImageSrc;
                  causeImage.alt = causeTitleText;
                }
                causeCard.classList.remove("hidden");
              } else {
                causeCard.classList.add("hidden");
              }
            }

            updateUI();
          });
        }

        const focusCustom =
          allowCustom &&
          (params.get("custom") === "1" || params.get("amount") === "custom");
        if (focusCustom && customInput) {
          amount = 0;
          customInput.value = "";
          setTimeout(() => {
            customInput.focus();
            customInput.scrollIntoView({ behavior: "smooth", block: "center" });
          }, 50);
        }

        function saveState() {
          sessionStorage.setItem(
            storageKey,
            JSON.stringify({
              amount,
              frequency,
              method,
              locale,
              custom: customInput?.value !== "",
            }),
          );
        }

        function filterPaymentMethods() {
          methodsEl.querySelectorAll("button").forEach((btn) => {
            const m = btn.dataset.method;
            if (m && !methodsAllowed.includes(m)) btn.classList.add("hidden");
            else btn.classList.remove("hidden");
          });
          if (!methodsAllowed.includes(method))
            method = methodsAllowed[0] || "card";
        }

        function updateUI() {
          amountGrid.querySelectorAll("button").forEach((btn) => {
            const a = parseInt(btn.dataset.amount || "", 10);
            btn.textContent = fmt(a);
            btn.className =
              a === amount && (!customInput || customInput.value === "")
                ? "py-3 text-center font-bold text-base rounded-md border transition-all bg-qcRed text-white border-qcRed"
                : "py-3 text-center font-bold text-base rounded-md border transition-all bg-white text-qcBlack border-gray-200 hover:border-qcRed";
          });

          freqToggle?.querySelectorAll("button").forEach((btn) => {
            btn.className =
              btn.dataset.frequency === frequency
                ? "qc-btn flex-1 py-3 rounded-md border border-gray-200 bg-qcRed text-white"
                : "qc-btn flex-1 py-3 rounded-md border border-gray-200 bg-white text-qcBlack";
          });

          methodsEl.querySelectorAll("button").forEach((btn) => {
            btn.className =
              btn.dataset.method === method
                ? "flex items-center justify-center gap-2 py-3 px-3 rounded-md border border-qcRed bg-red-50 text-xs font-bold transition-all"
                : "flex items-center justify-center gap-2 py-3 px-3 rounded-md border border-gray-200 bg-white text-xs font-bold transition-all";
          });

          filterPaymentMethods();
          submitAmount.textContent = fmt(amount);

          // Tiered impact swap — only relevant when the page picked the
          // "tiered" impact kind (other kinds don't render `.dfc-impact`).
          if (impactText) {
            let impactKey = "generic";
            if (amount >= 250) impactKey = "equipment";
            else if (amount >= 100) impactKey = "surgery";
            else if (amount >= 50) impactKey = "prenatal";
            else if (amount >= 25) impactKey = "consultation";

            const span = card.querySelector(
              `[data-impact="${impactKey}"]`,
            ) as HTMLElement | null;
            if (span) impactText.textContent = span.textContent || "";
          }
        }

        amountGrid.addEventListener("click", (e) => {
          const btn = (e.target as HTMLElement).closest("button");
          if (!btn?.dataset.amount) return;
          amount = parseInt(btn.dataset.amount, 10);
          if (customInput) customInput.value = "";
          updateUI();
          saveState();
        });

        customInput?.addEventListener("focus", () => {
          const val = parse(customInput.value);
          customInput.value = val > 0 ? String(val) : "";
        });

        customInput?.addEventListener("input", () => {
          const val = parseInt(customInput.value.replace(/[^\d]/g, ""), 10);
          if (val > 0) {
            amount = val;
            updateUI();
            saveState();
          }
        });

        customInput?.addEventListener("blur", () => {
          const val = parse(customInput.value);
          customInput.value = val > 0 ? fmt(val) : "";
        });

        freqToggle?.addEventListener("click", (e) => {
          const btn = (e.target as HTMLElement).closest("button");
          if (!btn?.dataset.frequency) return;
          frequency = btn.dataset.frequency;
          // When the amount is locked from a tier-style modal trigger,
          // scale the displayed total by the period multiplier so the
          // submit button always shows the actual charge for the
          // selected frequency (monthly = 1×, quarterly = 3×, yearly =
          // 12×). The locked monthly value stays the source of truth.
          if (lockedMonthlyAmount !== null) {
            amount = scaleAmount();
          }
          updateUI();
          saveState();
        });

        methodsEl.addEventListener("click", (e) => {
          const btn = (e.target as HTMLElement).closest("button");
          if (!btn?.dataset.method) return;
          method = btn.dataset.method;
          updateUI();
          saveState();
        });

        submitBtn.addEventListener("click", async () => {
          submitBtn.setAttribute("disabled", "true");
          // submitIcon is an SVG — its `className` is a read-only
          // SVGAnimatedString, so use setAttribute.
          submitIcon.setAttribute("class", "dfc-icon animate-spin mr-2");

          try {
            const res = await fetch("/api/mollie/create-payment", {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify({
                amount,
                frequency,
                method,
                locale,
                context,
                metadata,
                // Pass the override through only when the caller set
                // one; an empty string would be treated as "no override"
                // server-side anyway, but staying explicit avoids
                // surprises during debugging.
                description: descriptionOverride || undefined,
              }),
            });

            const data = await res.json();
            if (data.checkoutUrl) {
              if (data.paymentId) {
                sessionStorage.setItem(`mollie:${scopeId}`, data.paymentId);
                // Beacon — capture the redirect to Mollie's checkout
                // page. sendBeacon survives the navigation away, so
                // we can later distinguish "abandoned before checkout"
                // from "abandoned at checkout". Wrapped in try/catch
                // because a beacon failure must never block the donor
                // from being redirected.
                try {
                  navigator.sendBeacon(
                    "/api/donations/event",
                    new Blob(
                      [
                        JSON.stringify({
                          paymentId: data.paymentId,
                          type: "checkout_redirected",
                          payload: { scopeId },
                        }),
                      ],
                      { type: "application/json" },
                    ),
                  );
                } catch {
                  /* sendBeacon unsupported / blocked — not critical */
                }
              }
              window.location.href = data.checkoutUrl;
              return;
            }
            if (data.error) alert(data.error);
          } catch {
            alert("Something went wrong. Please try again.");
          }

          submitBtn.removeAttribute("disabled");
          submitIcon.setAttribute("class", "dfc-icon mr-2");
        });

        updateUI();
      });
  });
</script>
