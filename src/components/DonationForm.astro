<!-- Success overlay -->
<div
  id="success-overlay"
  class="fixed inset-0 z-[100] bg-white flex items-center justify-center hidden"
>
  <div class="text-center px-6">
    <div
      class="w-20 h-20 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-8"
    >
      <Icon name="check" class="text-green-600 text-3xl" />
    </div>
    <h2 class="text-4xl font-bold tracking-tighter uppercase mb-4">
      {t("donate.thankYouTitle")}
    </h2>
    <p class="text-gray-500 text-sm leading-relaxed max-w-md mx-auto mb-8">
      {t("donate.thankYouMessage")}
    </p>
    <a
      href={getLocalizedPath("/", lang)}
      class="qc-btn qc-btn--primary inline-block px-8 py-4"
    >
      {t("donate.backHome")}
    </a>
  </div>
</div>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const wrap = document.querySelector<HTMLElement>(
      "[data-donate-hero-counter]",
    );
    if (!wrap) return;

    const target = wrap.querySelector<HTMLElement>(
      '[data-stat-value="patients"]',
    );
    if (!target) return;

    const locale = wrap.dataset.locale ?? "en-US";
    const formatter = new Intl.NumberFormat(locale);
    const reduceMotion = window.matchMedia(
      "(prefers-reduced-motion: reduce)",
    ).matches;

    function easeOutCubic(t: number) {
      return 1 - Math.pow(1 - t, 3);
    }

    function countUp(el: HTMLElement, value: number, duration = 1800) {
      if (reduceMotion) {
        el.textContent = formatter.format(value);
        return;
      }
      const start = performance.now();
      function frame(now: number) {
        const elapsed = now - start;
        const progress = Math.min(elapsed / duration, 1);
        el.textContent = formatter.format(
          Math.round(value * easeOutCubic(progress)),
        );
        if (progress < 1) requestAnimationFrame(frame);
      }
      requestAnimationFrame(frame);
    }

    // Skip the EMR stats fetch on localhost (covers Lighthouse runs
    // against the static dist on a temp port, and local dev where there
    // is no EMR upstream).
    if (location.hostname !== "localhost")
      fetch("/api/statistics")
        .then((res) => (res.ok ? res.json() : null))
        .then((stats: Record<string, number> | null) => {
          if (stats && typeof stats.patients === "number") {
            countUp(target, stats.patients);
          }
        })
        .catch(() => {
          /* keep fallback "0" */
        });
  });
</script>
