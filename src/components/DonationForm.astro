---
import Icon from "./Icon.astro";
import { Image } from "astro:assets";
import {
  getLangFromUrl,
  useTranslations,
  getLocalizedPath,
  type Lang,
} from "../i18n";
import { getCurrency, formatCurrency } from "../lib/currency";
import { donationTiers } from "../lib/donationTiers";
import DonationFormCard from "./DonationFormCard.astro";
import heroImage from "../assets/images/hospital_exterior.jpg";

interface Props {
  lang?: Lang;
}

const lang = Astro.props.lang ?? getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const cc = getCurrency(lang);

const localeMap: Record<Lang, string> = {
  nl: "nl-NL",
  en: "en-US",
  es: "es-ES",
};
const numberLocale = localeMap[lang];
---

<!-- SECTION 1: Hero with floating donation form -->
<header
  class="relative min-h-screen bg-qcBlack flex items-center overflow-hidden"
>
  <div class="absolute inset-0 z-0">
    <Image
      src={heroImage}
      alt=""
      class="w-full h-full object-cover opacity-50"
      loading="eager"
      decoding="async"
      fetchpriority="high"
      format="webp"
      quality={70}
      widths={[480, 800, 1200, 1600]}
      sizes="100vw"
    />
    <div
      class="absolute inset-0 bg-gradient-to-r from-qcBlack via-qcBlack/80 to-qcBlack/40"
    >
    </div>
  </div>

  <div
    class="relative z-10 max-w-[1600px] mx-auto px-6 w-full py-32 flex flex-col lg:flex-row items-center gap-16"
  >
    <!-- Left: Title + Counter -->
    <div class="flex-1 text-center lg:text-left">
      <span class="qc-label mb-8">
        {t("hero.foundation")}
      </span>
      <h1
        class="text-4xl md:text-6xl lg:text-7xl font-bold text-white leading-[0.9] tracking-tighter mb-8"
      >
        {t("donate.pageTitle")}
      </h1>
      <p
        class="qc-body--light max-w-lg mb-12 font-light leading-relaxed mx-auto lg:mx-0"
      >
        {t("donate.pageSubtitle")}
      </p>

      <!-- Live counter -->
      <div class="flex items-center gap-4 justify-center lg:justify-start">
        <div class="flex items-center gap-2">
          <span class="relative flex h-2.5 w-2.5">
            <span
              class="animate-ping absolute inline-flex h-full w-full rounded-full bg-qcRed opacity-75"
            ></span>
            <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-qcRed"
            ></span>
          </span>
        </div>
        <div data-donate-hero-counter data-locale={numberLocale}>
          <span
            class="text-white font-bold text-4xl md:text-5xl tracking-tighter"
            data-stat-value="patients">0</span
          >
          <span class="text-white/50 text-sm block mt-1"
            >{t("donate.counterLabel")}</span
          >
        </div>
      </div>
    </div>

    <!-- Right: Floating donation form card -->
    <div
      class="w-full lg:w-[460px] flex-shrink-0 bg-white rounded-xl shadow-2xl p-8"
    >
      <DonationFormCard
        lang={lang}
        scopeId="donate-page"
        restoreFrequency={false}
      />
    </div>
  </div>
</header>

<!-- SECTION 2: Impact CTA (cards from donationTiers config) -->
<section class="py-24 bg-white border-b border-gray-100">
  <div class="max-w-7xl mx-auto px-6">
    <div class="text-center mb-16">
      <span class="qc-label mb-4">{t("donation.directImpact")}</span>
      <h2 class="text-4xl font-bold tracking-tighter uppercase mb-4">
        {t("donation.title")}
      </h2>
      <p class="qc-body max-w-xl mx-auto leading-relaxed">
        {t("donation.subtitle")}
      </p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
      {
        donationTiers.map((tier, i) => {
          const copy = tier.i18n[lang];
          const bg = i % 2 === 1 ? "bg-qcGray/30" : "";
          return (
            <div
              class:list={[
                "group border border-gray-100 p-8 hover:border-qcRed transition-all duration-500 relative overflow-hidden rounded-md",
                bg,
              ]}
            >
              <div class="absolute top-0 right-0 p-4 opacity-5 group-hover:opacity-10 transition-opacity">
                <Icon name={tier.icon} class="text-6xl" />
              </div>
              <h3 class="text-qcRed font-bold text-5xl tracking-tighter mb-6">
                {formatCurrency(tier.amount, cc, false)}
              </h3>
              <h4 class="text-lg font-bold uppercase tracking-tight mb-4">
                {copy.title}
              </h4>
              <p class="qc-body leading-relaxed">{copy.description}</p>
            </div>
          );
        })
      }
    </div>
  </div>
</section>

