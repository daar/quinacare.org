---
import { icons } from "../data/icons";

interface Props {
  /**
   * Icon name — either a bare key ("heart") or a legacy Font Awesome class
   * string ("fa-solid fa-heart"), so data-driven icons keep working.
   */
  name: string;
  class?: string;
  /** Optional id on the rendered <svg> — useful when JS needs to target it. */
  id?: string;
  /** Accessible name. Omit for decorative icons (rendered aria-hidden). */
  label?: string;
}

const { name, class: className, id, label } = Astro.props;

const key = name
  .split(/\s+/)
  .map((t) => t.replace(/^fa-/, ""))
  .find((t) => t in icons);
const icon = key ? icons[key] : undefined;
---

{
  icon && (
    <svg
      viewBox={icon.viewBox}
      class={className}
      id={id}
      fill="currentColor"
      role={label ? "img" : undefined}
      aria-label={label}
      aria-hidden={label ? undefined : "true"}
      set:html={icon.body}
    />
  )
}

<style>
  svg {
    display: inline-block;
    width: 1em;
    height: 1em;
    vertical-align: -0.125em;
  }
</style>
