---
import { languages, getLangFromUrl, switchPath, type Lang } from "../i18n";
import { buildPostTranslator } from "../lib/postTranslations";

const currentUrl = Astro.url;
const currentLang = (Astro.currentLocale as Lang) ?? getLangFromUrl(currentUrl);
const currentPath = currentUrl.pathname;
const langEntries = Object.entries(languages) as [Lang, string][];
const translatePostSlug = await buildPostTranslator();
---

<nav aria-label="Language switcher" class="flex items-center gap-2">
  {
    langEntries.map(([code, name], index) => {
      const isActive = code === currentLang;
      const href = switchPath(currentPath, code, translatePostSlug);

      return (
        <>
          {index > 0 && (
            <span class="text-gray-300" aria-hidden="true">
              |
            </span>
          )}
          <a
            href={href}
            class:list={[
              "uppercase transition-colors duration-200 hover:text-qcRed",
              isActive ? "text-qcBlack font-bold" : "text-gray-400",
            ]}
            aria-current={isActive ? "page" : undefined}
            aria-label={`Switch to ${name}`}
            hreflang={code}
            lang={code}
            data-lang-switch={code}
          >
            {code.toUpperCase()}
          </a>
        </>
      );
    })
  }
</nav>

<script>
  // Remember the visitor's explicit language choice so the root-path
  // redirect in Layout honors it on the next visit. Delegated so it
  // covers every LanguageSwitcher instance (desktop + mobile nav).
  document.addEventListener("click", (event) => {
    if (!(event.target instanceof Element)) return;
    const link = event.target.closest<HTMLElement>("[data-lang-switch]");
    const lang = link?.dataset.langSwitch;
    if (!lang) return;
    try {
      localStorage.setItem("qc-lang", lang);
    } catch {
      /* storage unavailable */
    }
  });
</script>
