---
import {
  getLangFromUrl,
  useTranslations,
  getLocalizedPath,
  type Lang,
} from "../i18n";
import { premiumPartners } from "../data/partners";
import OptimizedImage from "./OptimizedImage.astro";

interface Props {
  lang?: Lang;
}

const lang = Astro.props.lang ?? getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section class="border-y border-gray-100 py-20">
  <div class="max-w-[1600px] mx-auto px-6">
    <div class="grid lg:grid-cols-12 gap-12 items-center">
      <div class="lg:col-span-5">
        <span class="qc-label mb-4">{t("partners.label")}</span>
        <h2 class="text-3xl font-bold text-qcBlack leading-tight mb-4">
          {t("partners.title")}
        </h2>
        <p class="qc-body leading-relaxed max-w-md italic">
          {t("partners.subtitle")}
        </p>
      </div>

      <div class="lg:col-span-7 flex flex-col gap-12">
        <div
          class="flex flex-wrap items-center justify-start gap-x-12 gap-y-10"
        >
          {
            premiumPartners.map((partner) => (
              <a
                href={partner.url}
                target="_blank"
                rel="noopener noreferrer"
                class="group relative flex items-center justify-center transition-all duration-300"
              >
                <OptimizedImage
                  src={partner.logo}
                  alt={partner.name}
                  class="h-20 w-auto max-w-[140px] object-contain lg:grayscale lg:opacity-40 group-hover:grayscale-0 group-hover:opacity-100 group-hover:scale-110 transition-all duration-500 ease-out"
                />
              </a>
            ))
          }
        </div>

        <div class="flex items-center gap-6 pt-4 border-t border-gray-100">
          <a
            href={getLocalizedPath("/become-partner", lang)}
            class="qc-btn qc-btn--secondary group flex items-center gap-3 px-6 py-3"
          >
            <span>{t("partners.viewAll")}</span>
            <i
              class="fa-solid fa-arrow-right-long transition-transform group-hover:translate-x-1"
            ></i>
          </a>
          <span class="qc-meta">
            {t("partners.interested")}
            <a
              href={getLocalizedPath("/contact", lang)}
              class="text-qcRed hover:underline ml-1">{t("partners.contact")}</a
            >
          </span>
        </div>
      </div>
    </div>
  </div>
</section>
