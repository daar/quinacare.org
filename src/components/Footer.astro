---
import {
  getLangFromUrl,
  useTranslations,
  getLocalizedPath,
  type Lang,
} from "../i18n";

interface Props {
  lang?: Lang;
}

const lang = Astro.props.lang ?? getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<footer class="bg-qcBlack pt-20 pb-10 text-white">
  <div class="max-w-[1600px] mx-auto px-6">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 mb-20">
      <div class="space-y-6">
        <img
          src="/logo-quina-care.svg"
          alt="Quina Care"
          class="h-12 brightness-0 invert"
        />
        <p class="text-white/50 text-lg leading-relaxed max-w-xs">
          {t("footer.description")}
        </p>
        <div class="flex gap-4 text-white/40">
          <a href="#" class="hover:text-white transition-colors text-lg"
            ><i class="fa-brands fa-instagram"></i></a
          >
          <a href="#" class="hover:text-white transition-colors text-lg"
            ><i class="fa-brands fa-linkedin"></i></a
          >
          <a href="#" class="hover:text-white transition-colors text-lg"
            ><i class="fa-brands fa-facebook"></i></a
          >
        </div>
      </div>

      <div>
        <h4 class="qc-footer-heading mb-8">
          {t("footer.organization")}
        </h4>
        <ul class="space-y-4 text-white/50 text-base uppercase tracking-widest">
          <li>
            <a href="#" class="hover:text-white transition-colors"
              >{t("footer.aboutUs")}</a
            >
          </li>
          <li>
            <a href="#" class="hover:text-white transition-colors"
              >{t("footer.ourProjects")}</a
            >
          </li>
          <li>
            <a
              href={getLocalizedPath("/news", lang)}
              class="hover:text-white transition-colors"
              >{t("footer.newsPosts")}</a
            >
          </li>
          <li>
            <a href="#" class="hover:text-white transition-colors"
              >{t("footer.financialReport")}</a
            >
          </li>
        </ul>
      </div>

      <div>
        <h4 class="qc-footer-heading mb-8">
          {t("footer.contact")}
        </h4>
        <ul class="space-y-4 text-white/50 text-base">
          <li class="flex items-start gap-3">
            <i class="fa-solid fa-envelope mt-1 text-white/50"></i>
            <a
              href="mailto:info@quinacare.org"
              class="hover:text-white transition-colors">info@quinacare.org</a
            >
          </li>
          <li class="flex items-start gap-3">
            <i class="fa-solid fa-location-dot mt-1 text-white/50"></i>
            <span>IJsvogellaan 76<br />2261 DK Leidschendam</span>
          </li>
        </ul>
      </div>

      <div>
        <h4 class="qc-footer-heading mb-8">{t("footer.certifications")}</h4>
        <div class="flex flex-wrap gap-4">
          <a
            href="https://www.belastingdienst.nl/wps/wcm/connect/bldcontentnl/belastingdienst/zakelijk/bijzondere_regelingen/goede_doelen/algemeen_nut_beogende_instellingen/wat_is_een_anbi"
            target="_blank"
            rel="noopener noreferrer"
          >
            <img
              src="/images/certifications/anbi.png"
              alt="ANBI"
              class="h-12 opacity-40 grayscale hover:grayscale-0 hover:opacity-100 transition-all duration-500"
            />
          </a>
          <a
            href="https://www.cbf.nl/organisatie/quina-care"
            target="_blank"
            rel="noopener noreferrer"
          >
            <img
              src="/images/certifications/cbf.png"
              alt="CBF Erkend Goed Doel"
              class="h-12 opacity-40 grayscale hover:grayscale-0 hover:opacity-100 transition-all duration-500"
            />
          </a>
          {
            lang === "en" && (
              <a
                href="https://www.centerfornonprofits.org/"
                target="_blank"
                rel="noopener noreferrer"
              >
                <img
                  src="/images/certifications/certified-nonprofit.png"
                  alt="Certified Nonprofit"
                  class="h-12 opacity-40 grayscale hover:grayscale-0 hover:opacity-100 transition-all duration-500"
                />
              </a>
            )
          }
        </div>
        <p
          class="mt-6 text-sm text-white/30 leading-relaxed uppercase tracking-widest"
        >
          {t("footer.certifiedCharity")}
        </p>
      </div>
    </div>

    <div
      class="qc-meta pt-10 border-t border-white/5 flex flex-col md:flex-row justify-between items-center gap-6 !text-white/30"
    >
      <div class="flex gap-8">
        <p>&copy; 2026 Quina Care</p>
        <a href="#" class="hover:text-white transition-colors"
          >{t("footer.privacyPolicy")}</a
        >
        <a href="#" class="hover:text-white transition-colors"
          >{t("footer.cookies")}</a
        >
      </div>
    </div>
  </div>
</footer>
