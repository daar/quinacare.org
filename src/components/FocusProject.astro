---
import OptimizedImage from "./OptimizedImage.astro";
import {
  getLangFromUrl,
  useTranslations,
  getLocalizedPath,
  type Lang,
} from "../i18n";

interface Props {
  lang?: Lang;
}

const lang = Astro.props.lang ?? getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section class="bg-qcGray py-24 border-y border-gray-100">
  <div class="max-w-7xl mx-auto px-6 grid md:grid-cols-2 gap-16 items-center">
    <div class="rounded-2xl overflow-hidden shadow-xl">
      <OptimizedImage
        src="/media/2024/11/HPV-project.png"
        alt={t("focus.title")}
        class="w-full h-[500px] object-cover"
        widths={[400, 600]}
        sizes="(max-width: 768px) 100vw, 50vw"
      />
    </div>
    <div>
      <span class="qc-label mb-4">{t("focus.label")}</span>
      <h2 class="text-4xl font-bold mb-6">{t("focus.title")}</h2>
      <p class="qc-body mb-8 leading-relaxed">
        {t("focus.description")}
      </p>
      <a
        href={getLocalizedPath("/projects/hpv-screening", lang)}
        class="qc-btn qc-btn--primary inline-block px-10 py-4"
      >
        {t("focus.cta")}
      </a>
    </div>
  </div>
</section>
