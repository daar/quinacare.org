---
import Icon from "./Icon.astro";
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import {
  getLangFromUrl,
  useTranslations,
  getLocalizedPath,
  getDateLocale,
  getCollectionName,
  type Lang,
} from "../i18n";
import { selectNews } from "../lib/news";

interface Props {
  lang?: Lang;
}

const lang = Astro.props.lang ?? getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const dateLocale = getDateLocale(lang);

// Pinned posts claim a slot first, the rest fill with the newest non-pinned,
// and the four shown are rendered newest-first. See selectNews.
const posts = selectNews(
  (await getCollection(getCollectionName(lang))).filter(
    (post) => post.data.status === "publish",
  ),
  4,
);

function formatDate(date: Date): string {
  return new Intl.DateTimeFormat(dateLocale, {
    day: "numeric",
    month: "short",
    year: "numeric",
  }).format(date);
}
---

<section class="py-24 max-w-7xl mx-auto px-6">
  {
    posts.length > 0 ? (
      <>
        <div class="flex justify-between items-end mb-16">
          <h2 class="text-3xl font-bold uppercase tracking-tighter">
            {t("homeNews.title")}
            <span class="text-qcRed italic underline decoration-1 underline-offset-8">
              {t("homeNews.subtitle")}
            </span>
          </h2>
          <a
            href={getLocalizedPath("/news", lang)}
            class="text-sm font-bold border-b border-qcBlack hover:text-qcRed hover:border-qcRed transition"
          >
            {t("homeNews.allPosts")}
          </a>
        </div>

        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-8">
          {posts.map((post) => (
            <a
              href={getLocalizedPath(
                `/news/${post.data.slug || post.id}`,
                lang,
              )}
              class="group"
            >
              <div class="aspect-[4/3] mb-6 overflow-hidden bg-gray-100 rounded-xl">
                {post.data.featured_image ? (
                  <Image
                    src={post.data.featured_image}
                    alt={post.data.title}
                    class="w-full h-full object-cover group-hover:scale-105 transition duration-700"
                    widths={[300, 600]}
                    sizes="(max-width: 768px) 100vw, 400px"
                  />
                ) : (
                  <div class="w-full h-full bg-gradient-to-br from-gray-100 to-gray-200" />
                )}
              </div>
              <div class="qc-meta flex items-center gap-3 mb-3">
                <span class="flex items-center gap-1.5">
                  <Icon name="calendar" />
                  {formatDate(post.data.date)}
                </span>
              </div>
              <h3 class="text-xl font-bold group-hover:text-qcRed transition uppercase leading-tight">
                {post.data.title}
              </h3>
              {post.data.excerpt && (
                <p class="qc-body mt-4 line-clamp-2">{post.data.excerpt}</p>
              )}
            </a>
          ))}
        </div>
      </>
    ) : (
      <div class="bg-gray-50 border border-gray-100 rounded-xl p-12 md:p-16 text-center max-w-2xl mx-auto">
        <Icon name="pen-ruler" class="text-qcRed text-3xl mb-6" />
        <h3 class="text-2xl font-bold uppercase tracking-tight mb-3">
          {t("homeNews.placeholderTitle")}
        </h3>
        <p class="qc-body">{t("homeNews.placeholderMessage")}</p>
      </div>
    )
  }
</section>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
