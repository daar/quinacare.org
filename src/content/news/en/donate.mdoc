window.onload = function () {
var dmm\_dd = document.getElementById('dmm\_dd');
if (dmm\_dd !== null) {
if (dmm\_dd.value !== '--') {
document.getElementById('dmm\_amount').value = document.getElementById('dmm\_dd').value.replace(',', '.');
document.getElementById('dmm\_amount').style.display = 'none';
}
}
if (document.getElementById('dmm\_interval').value !== 'one') {
document.getElementById('dmm\_permission').style.display = 'block';
}
dmm\_recurring\_methods(document.getElementById('dmm\_interval').value);
dmm\_multicurrency\_methods(document.getElementById('dmm\_currency').value);
}

