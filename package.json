{
  "name": "quinacare.org",
  "type": "module",
  "version": "0.0.1",
  "description": "Website of Stichting Quina Care - medical care for the most remote areas of the Amazon.",
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "npm run svg:minify && astro dev",
    "build": "npm run svg:minify && astro build && npx pagefind --site dist",
    "check": "astro check",
    "lint": "eslint .",
    "spellcheck": "cspell \"src/content/**/*.mdoc\"",
    "format:check": "prettier --check .",
    "svg:minify": "svgo -r --folder src/assets --quiet --exclude instagram.svg --exclude Asset-2.svg && svgo -r --folder public --quiet --exclude favicon.svg",
    "check:images": "node scripts/check-image-sizes.mjs",
    "check:links": "linkinator dist --recurse --skip '.netlify/images|localhost'",
    "lighthouse": "npx --yes @lhci/cli@0.14.0 autorun",
    "mollie-admin": "node --env-file=.env tools/mollie-admin/server.mjs",
    "test": "node --test --experimental-strip-types 'tests/**/*.test.ts'",
    "preview": "astro preview",
    "astro": "astro",
    "prepare": "husky"
  },
  "overrides": {
    "yaml": "^2.9.0"
  },
  "dependencies": {
    "@astrojs/markdoc": "^1.0.6",
    "@astrojs/netlify": "^7.0.13",
    "@astrojs/sitemap": "^3.7.3",
    "@libsql/client": "^0.17.4",
    "@mollie/api-client": "^4.5.0",
    "@tailwindcss/vite": "^4.3.1",
    "@types/leaflet": "^1.9.21",
    "astro": "^6.4.6",
    "leaflet": "^1.9.4",
    "nodemailer": "^9.0.1",
    "qrcode": "^1.5.4",
    "sharp": "^0.35.2",
    "swiper": "^12.2.0",
    "tailwindcss": "^4.2.1"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@cspell/dict-es-es": "^3.0.8",
    "@cspell/dict-nl-nl": "^2.4.2",
    "@eslint/js": "^10.0.1",
    "@types/nodemailer": "^8.0.1",
    "@types/qrcode": "^1.5.6",
    "cspell": "^10.0.1",
    "eslint": "^10.5.0",
    "eslint-plugin-astro": "^1.7.0",
    "husky": "^9.1.7",
    "linkinator": "^7.6.1",
    "lint-staged": "^17.0.8",
    "pagefind": "^1.5.2",
    "prettier": "^3.8.4",
    "prettier-plugin-astro": "^0.14.1",
    "svgo": "^4.0.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.61.1"
  },
  "lint-staged": {
    "*.{js,ts,mjs,cjs,json,css,md}": "prettier --write",
    "*.astro": "prettier --write --plugin prettier-plugin-astro",
    "*.mdoc": "cspell --no-must-find-files"
  }
}
