{
  "name": "quinacare.org",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "npm run svg:minify && astro dev",
    "build": "npm run svg:minify && astro build && npx pagefind --site dist",
    "check": "astro check",
    "lint": "eslint .",
    "spellcheck": "cspell \"src/content/**/*.mdoc\"",
    "format:check": "prettier --check .",
    "svg:minify": "svgo -r src/assets public --quiet",
    "check:links": "linkinator dist --recurse --skip '.netlify/images|localhost'",
    "preview": "astro preview",
    "astro": "astro",
    "prepare": "husky"
  },
  "dependencies": {
    "@astrojs/markdoc": "^0.15.10",
    "@astrojs/netlify": "^6.6.4",
    "@libsql/client": "^0.17.0",
    "@mollie/api-client": "^4.4.0",
    "@tailwindcss/vite": "^4.2.1",
    "astro": "^5.17.1",
    "nodemailer": "^8.0.2",
    "tailwindcss": "^4.2.1"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.6",
    "@cspell/dict-es-es": "^3.0.8",
    "@cspell/dict-nl-nl": "^2.4.2",
    "@eslint/js": "^10.0.1",
    "@types/nodemailer": "^7.0.11",
    "cspell": "^9.7.0",
    "eslint": "^10.0.2",
    "eslint-plugin-astro": "^1.6.0",
    "husky": "^9.1.7",
    "linkinator": "^7.6.1",
    "lint-staged": "^16.3.1",
    "pagefind": "^1.4.0",
    "prettier": "^3.8.1",
    "prettier-plugin-astro": "^0.14.1",
    "svgo": "^4.0.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "lint-staged": {
    "*.{js,ts,mjs,cjs,json,css,md}": "prettier --write",
    "*.astro": "prettier --write --plugin prettier-plugin-astro",
    "*.mdoc": "cspell --no-must-find-files"
  }
}
